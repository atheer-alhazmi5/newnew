@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>خطأ - نظام إدارة النماذج</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
    <style>
        body { font-family:'Cairo',sans-serif; display:flex; align-items:center; justify-content:center; min-height:100vh; background:#f5f5f5; }
        .error-box { text-align:center; background:#fff; padding:60px; border-radius:16px; box-shadow:0 4px 24px rgba(0,0,0,.08); max-width:500px; }
        .error-code { font-size:80px; font-weight:800; color:#14573A; line-height:1; margin-bottom:16px; }
    </style>
</head>
<body>
    <div class="error-box">
        <div class="error-code">⚠️</div>
        <h2 style="font-weight:700;color:#1F2A37;">حدث خطأ</h2>
        <p style="color:#6C737F;margin-bottom:32px;">عذراً، حدث خطأ غير متوقع. يرجى المحاولة مرة أخرى.</p>
        <a href="/" class="btn btn-primary">العودة للرئيسية</a>
    </div>
</body>
</html>

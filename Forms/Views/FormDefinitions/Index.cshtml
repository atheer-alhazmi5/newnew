@{
    ViewBag.Title = "النماذج المستخدمة";
    ViewBag.PageName = "النماذج المستخدمة";
}

<style>
/* ── page-specific overrides ── */
.fd-modal        { border-radius:20px; border:none; overflow:hidden; box-shadow:0 20px 60px rgba(0,0,0,.15); }
.fd-modal-header { padding:24px 28px; position:relative; }
.fd-modal-header.create  { background:var(--sa-800); }
.fd-modal-header.edit    { background:var(--sa-800); }
.fd-modal-header.details { background:var(--info-700); }
.fd-modal-header.danger  { background:var(--error-600); }
.fd-modal-header .btn-close-x { position:absolute; top:16px; left:16px; background:none; border:none; color:rgba(255,255,255,.7); font-size:22px; cursor:pointer; }
.fd-modal-header .btn-close-x:hover { color:#fff; }
.fd-modal-title    { color:#fff; font-weight:800; font-size:20px; margin:0; }
.fd-modal-subtitle { color:rgba(255,255,255,.8); font-size:14px; margin-top:4px; }
.fd-modal-body   { padding:28px; max-height:75vh; overflow-y:auto; }
.fd-modal-footer { padding:20px 28px; display:flex; flex-wrap:wrap; gap:12px; border:none; justify-content:space-between; align-items:center; background:var(--gray-50); }

/* Sections inside modal */
.fd-section       { background:#fff; border-radius:12px; padding:18px 20px; margin-bottom:16px; border:1px solid var(--gray-200); }
.fd-section-title { font-weight:700; font-size:14px; color:var(--sa-800); margin:0 0 14px; padding-bottom:10px; border-bottom:2px solid var(--sa-100); display:flex; align-items:center; gap:8px; }
.fd-section-title i { font-size:15px; color:var(--sa-600); }
.fd-form-row   { display:grid; grid-template-columns:repeat(2,1fr); gap:14px; margin-bottom:14px; }
.fd-form-row.cols-3 { grid-template-columns:repeat(3,1fr); }
.fd-form-row.cols-1 { grid-template-columns:1fr; }
.fd-form-group { display:flex; flex-direction:column; gap:4px; }
.fd-form-group label { font-weight:700; font-size:13px; color:var(--gray-700); }
.fd-form-group .form-control,
.fd-form-group .form-select { font-size:13px; border-radius:10px; border:2px solid var(--gray-200); padding:8px 12px; font-family:'Cairo',sans-serif; }
.fd-form-group .form-control:focus,
.fd-form-group .form-select:focus { border-color:var(--sa-400); box-shadow:none; }
.fd-form-group textarea.form-control { min-height:70px; resize:vertical; }
.required-star { color:#ef4444; margin-right:4px; }

/* Action buttons in table */
.fd-action-btn { min-width:auto; border-radius:8px; font-weight:700; padding:5px 10px; font-size:11px; display:inline-flex; align-items:center; gap:4px; justify-content:center; cursor:pointer; border:2px solid transparent; font-family:'Cairo',sans-serif; white-space:nowrap; transition:all .15s; }
.fd-action-btn-detail { border-color:var(--info-500); color:var(--info-500); background:#fff; }
.fd-action-btn-detail:hover { background:var(--info-50); }
.fd-action-btn-edit   { border-color:var(--sa-600); color:var(--sa-600); background:#fff; }
.fd-action-btn-edit:hover { background:var(--sa-50); }
.fd-action-btn-delete { border-color:var(--error-500); color:var(--error-500); background:#fff; }
.fd-action-btn-delete:hover { background:var(--error-50); }
.fd-action-btn-approve { border-color:var(--success-600); color:var(--success-600); background:#fff; }
.fd-action-btn-approve:hover { background:var(--success-50); }
.fd-action-btn-reject { border-color:var(--error-500); color:var(--error-500); background:#fff; }
.fd-action-btn-reject:hover { background:var(--error-50); }
.fd-action-btn-send   { border-color:var(--warning-600); color:var(--warning-600); background:#fff; }
.fd-action-btn-send:hover { background:var(--warning-50); }

/* Status badges */
.fd-badge { display:inline-flex; align-items:center; gap:5px; padding:4px 11px; border-radius:20px; font-size:12px; font-weight:700; }
.fd-badge-draft    { background:var(--gray-100);   color:var(--gray-600); }
.fd-badge-pending  { background:var(--warning-100); color:var(--warning-700); }
.fd-badge-approved { background:var(--success-100); color:var(--success-700); }
.fd-badge-rejected { background:var(--error-100);   color:var(--error-700); }
.fd-owner-badge { display:inline-flex; align-items:center; gap:5px; padding:4px 11px; border-radius:20px; font-size:12px; font-weight:700; }
.fd-owner-public { background:var(--info-100); color:var(--info-700); }
.fd-owner-private { background:var(--warning-100); color:var(--warning-700); }
.fd-owner-none { background:var(--gray-100); color:var(--gray-500); }

/* Toggle */
.fd-toggle { position:relative; display:inline-block; width:42px; height:22px; }
.fd-toggle input { opacity:0; width:0; height:0; }
.fd-toggle .fd-slider { position:absolute; cursor:pointer; inset:0; background:var(--gray-300); border-radius:22px; transition:.25s; }
.fd-toggle .fd-slider::before { content:''; position:absolute; width:16px; height:16px; left:3px; bottom:3px; background:#fff; border-radius:50%; transition:.25s; }
.fd-toggle input:checked + .fd-slider { background:var(--sa-600); }
.fd-toggle input:checked + .fd-slider::before { transform:translateX(20px); }
.fd-toggle input:disabled + .fd-slider { opacity:.45; cursor:not-allowed; }

/* Wizard step bar */
.fd-steps { display:flex; border-bottom:1px solid var(--gray-200); background:#fff; }
.fd-step  { flex:1; padding:14px 12px; text-align:center; font-size:13px; font-weight:600; color:var(--gray-400); border-bottom:3px solid transparent; display:flex; align-items:center; justify-content:center; gap:7px; transition:all .2s; }
.fd-step.active { color:var(--sa-700); border-bottom-color:var(--sa-500); }
.fd-step.done   { color:var(--sa-500); }
.fd-step-num { width:22px; height:22px; border-radius:50%; background:var(--gray-200); color:var(--gray-500); font-size:11px; font-weight:800; display:inline-flex; align-items:center; justify-content:center; flex-shrink:0; }
.fd-step.active .fd-step-num { background:var(--sa-600); color:#fff; }
.fd-step.done   .fd-step-num { background:var(--sa-100); color:var(--sa-600); }

/* Fields list */
.fd-fields-list  { border:2px solid var(--gray-200); border-radius:10px; overflow:hidden; }
.fd-field-head   { background:var(--gray-50); padding:10px 14px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--gray-200); }
.fd-field-row    { display:flex; align-items:center; gap:10px; padding:9px 14px; border-bottom:1px solid var(--gray-100); background:#fff; transition:background .12s; }
.fd-field-row:last-child { border-bottom:none; }
.fd-field-row:hover { background:var(--sa-25); }
.fd-field-name   { flex:1; font-size:13px; font-weight:600; color:var(--gray-800); }
.fd-field-type   { font-size:11px; color:var(--sa-600); background:var(--sa-50); padding:2px 8px; border-radius:10px; font-weight:600; }
.fd-field-req    { font-size:10px; color:var(--error-700); background:var(--error-100); padding:2px 7px; border-radius:8px; font-weight:700; }
.fd-empty-fields { text-align:center; padding:28px 16px; color:var(--gray-400) !important; font-style:normal !important; }
.fd-empty-fields i { font-size:32px; display:block; margin-bottom:8px; color:var(--gray-300) !important; font-style:normal !important; }
.fd-empty-fields p { font-size:13px; font-weight:600; margin:0; font-style:normal !important; }

/* Add-field panel */
.fd-add-panel { background:var(--gray-50); border:2px dashed var(--gray-200); border-radius:10px; padding:16px; margin-top:12px; }
.fd-add-panel-title { font-size:13px; font-weight:700; color:var(--sa-700); margin-bottom:12px; display:flex; align-items:center; gap:6px; }

/* Details grid */
.fd-detail-grid { display:grid; grid-template-columns:140px 1fr; gap:10px 16px; font-size:13px; }
.fd-detail-lbl  { font-weight:700; color:var(--gray-500); }
.fd-detail-val  { color:var(--gray-800); font-weight:500; }

/* Empty state */
.fd-empty-state { text-align:center; padding:56px 16px; color:var(--gray-400) !important; font-style:normal !important; }
.fd-empty-state i { font-size:52px; display:block; margin-bottom:14px; color:var(--gray-300) !important; font-style:normal !important; }
.fd-empty-state p { font-size:14px; font-weight:600; margin:0; color:var(--gray-400) !important; font-style:normal !important; }

/* Save buttons */
.fd-save-btn        { padding:11px 28px; border-radius:12px; font-size:14px; font-weight:700; font-family:'Cairo',sans-serif; border:none; cursor:pointer; color:#fff; transition:all .15s; }
.fd-save-btn:hover  { transform:translateY(-1px); }
.fd-save-btn.draft  { background:var(--gray-500); }
.fd-save-btn.draft:hover { background:var(--gray-600); }
.fd-save-btn.send   { background:var(--sa-600); }
.fd-save-btn.send:hover  { background:var(--sa-700); }
.fd-cancel-btn      { padding:11px 28px; border-radius:12px; font-size:14px; font-weight:700; font-family:'Cairo',sans-serif; border:none; cursor:pointer; background:var(--gray-200); color:var(--gray-700); transition:all .15s; }
.fd-cancel-btn:hover { background:var(--gray-300); }

@@media (max-width:768px) {
    .fd-form-row { grid-template-columns:1fr; }
    .fd-form-row.cols-3 { grid-template-columns:1fr; }
    .fd-detail-grid { grid-template-columns:1fr; }
    .fd-steps { overflow-x:auto; }
}
</style>

<!-- =================== PAGE HEADER =================== -->
<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
    <div>
        <h2 class="page-title mb-0">النماذج المستخدمة</h2>
        <p style="color:var(--gray-500);font-size:14px;margin:6px 0 0;">إنشاء وإدارة النماذج المستخدمة في النظام </p>
    </div>
    <button type="button" class="btn btn-primary" onclick="fdShowCreate()" style="border-radius:12px;padding:10px 28px;">
        <i class="bi bi-plus-lg"></i> إنشاء نموذج جديد
    </button>
</div>

<!-- =================== FILTERS =================== -->
<div class="d-flex gap-3 mb-4 flex-wrap align-items-center rt-filters">
    <div class="rt-search-box">
        <i class="bi bi-search rt-search-icon"></i>
        <input type="text" class="form-control" id="fdSearch" placeholder="بحث باسم النموذج..." oninput="fdLoad()">
    </div>
    <select class="rt-filter-select form-select" id="fdFilterCat" onchange="fdLoad()">
        <option value="">التصنيف</option>
    </select>
    <select class="rt-filter-select form-select" id="fdFilterType" onchange="fdLoad()">
        <option value="">النوع</option>
    </select>
    <select class="rt-filter-select form-select" id="fdFilterStatus" onchange="fdLoad()">
        <option value="">الحالة</option>
        <option value="draft">مسودة</option>
        <option value="pending">بانتظار الاعتماد</option>
        <option value="approved">معتمد</option>
        <option value="rejected">مرفوض</option>
    </select>
    <button class="rt-clear-btn" onclick="fdClear()"><i class="bi bi-x-circle"></i> مسح</button>
</div>

<!-- =================== TABLE =================== -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0" id="fdTable">
                <thead>
                    <tr>
                        <th style="width:50px;text-align:center;">رقم</th>
                        <th>اسم النموذج</th>
                        <th>مساحة العمل</th>
                        <th>التصنيف</th>
                        <th>النوع</th>
                        <th>القالب</th>
                        <th style="text-align:center;">الملكية</th>
                        <th>الوحدة التنظيمية</th>
                        <th style="text-align:center;">الحالة</th>
                        <th style="text-align:center;display:none;" id="fdThActive">التفعيل</th>
                        <th style="text-align:center;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody id="fdBody">
                    <tr><td colspan="11" class="text-center py-4">
                        <div class="spinner-border" style="color:var(--sa-600);"></div>
                    </td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>


<!-- =================== WIZARD MODAL =================== -->
<div class="modal fade" id="fdWizardModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content fd-modal">
            <div class="fd-modal-header create" id="fdWizardHead">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="fd-modal-title" id="fdWizardTitle">إنشاء نموذج جديد</h5>
                <div class="fd-modal-subtitle" id="fdWizardSub">أدخل بيانات النموذج الجديد</div>
            </div>
            <!-- Step bar -->
            <div class="fd-steps" id="fdStepBar">
                <div class="fd-step active" id="fdStep1El">
                    <span class="fd-step-num">1</span> البيانات الأساسية
                </div>
                <div class="fd-step" id="fdStep2El">
                    <span class="fd-step-num">2</span> بناء الحقول
                </div>
                <div class="fd-step" id="fdStep3El">
                    <span class="fd-step-num">3</span> معاينة النموذج
                </div>
            </div>
            <div class="fd-modal-body" id="fdWizardBody"></div>
            <div class="fd-modal-footer" id="fdWizardFoot"></div>
        </div>
    </div>
</div>


<!-- =================== DETAILS MODAL =================== -->
<div class="modal fade" id="fdDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content fd-modal">
            <div class="fd-modal-header details">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="fd-modal-title">تفاصيل النموذج</h5>
                <div class="fd-modal-subtitle">عرض كامل لبيانات النموذج</div>
            </div>
            <div class="fd-modal-body" id="fdDetailsBody"></div>
            <div class="fd-modal-footer" style="justify-content:flex-end;">
                <button type="button" class="fd-cancel-btn" data-bs-dismiss="modal">إغلاق</button>
            </div>
        </div>
    </div>
</div>


<!-- =================== REJECT MODAL =================== -->
<div class="modal fade" id="fdRejectModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content fd-modal">
            <div class="fd-modal-header danger">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="fd-modal-title">رفض النموذج</h5>
                <div class="fd-modal-subtitle" id="fdRejectSub">الرجاء تحديد سبب الرفض</div>
            </div>
            <div class="fd-modal-body">
                <div class="fd-form-group">
                    <label><span class="required-star">*</span> سبب الرفض</label>
                    <textarea class="form-control" id="fdRejectReason" rows="3" placeholder="اكتب سبب الرفض هنا..."></textarea>
                </div>
            </div>
            <div class="fd-modal-footer" style="justify-content:flex-end;gap:10px;">
                <button type="button" class="fd-save-btn" style="background:var(--error-600);" onclick="fdSubmitReject()">
                    <i class="bi bi-x-lg"></i> رفض
                </button>
                <button type="button" class="fd-cancel-btn" data-bs-dismiss="modal">إلغاء</button>
            </div>
        </div>
    </div>
</div>


<!-- =================== DELETE MODAL =================== -->
<div class="modal fade" id="fdDeleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content fd-modal">
            <div class="fd-modal-header danger">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="fd-modal-title">تأكيد الحذف</h5>
                <div class="fd-modal-subtitle" id="fdDeleteSub">هذا الإجراء لا يمكن التراجع عنه</div>
            </div>
            <div class="fd-modal-body">
                <p style="font-size:14px;color:var(--gray-700);margin:0;">
                    هل أنت متأكد من حذف النموذج <strong id="fdDeleteName"></strong>؟
                </p>
            </div>
            <div class="fd-modal-footer" style="justify-content:flex-end;gap:10px;">
                <button type="button" class="fd-save-btn" style="background:var(--error-600);" onclick="fdSubmitDelete()">
                    <i class="bi bi-trash3"></i> حذف
                </button>
                <button type="button" class="fd-cancel-btn" data-bs-dismiss="modal">إلغاء</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/form-definitions.js" asp-append-version="true"></script>
<script>fdLoad();</script>
}

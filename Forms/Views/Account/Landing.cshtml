<div id="sysPopupContainer"></div>
<style>
.sys-popup-overlay { position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:10050;display:flex;align-items:center;justify-content:center;animation:lpFadeIn .25s ease; }
.sys-popup-box { border-radius:20px;overflow:hidden;box-shadow:0 8px 50px rgba(0,0,0,.28);max-width:440px;width:calc(100% - 40px);animation:lpSlideUp .3s ease; }
.sys-popup-head-ad    { background:linear-gradient(135deg,#079455,#16A34A);padding:18px 22px;color:#fff; }
.sys-popup-head-alert { background:linear-gradient(135deg,#CA8A04,#EAB308);padding:18px 22px;color:#fff; }
.sys-popup-body { background:#fff;padding:20px 22px; }
.sys-popup-footer { background:#fff;padding:0 22px 18px;display:flex;justify-content:center; }
.sys-popup-close { background:#fff;border:1.5px solid #E5E7EB;border-radius:20px;padding:7px 30px;font-weight:700;font-size:13px;color:#374151;cursor:pointer;font-family:'Cairo',sans-serif;transition:all .15s; }
.sys-popup-close:hover { background:#F9FAFB; }
@@keyframes lpFadeIn  { from { opacity:0; } to { opacity:1; } }
@@keyframes lpFadeOut { from { opacity:1; } to { opacity:0; } }
@@keyframes lpSlideUp { from { opacity:0;transform:translateY(30px); } to { opacity:1;transform:translateY(0); } }
</style>
<script>window.APP_PATH_BASE = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Context.Request.PathBase.Value ?? string.Empty));</script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
document.addEventListener('DOMContentLoaded', async function initLandingPopups() {
    const dismissed = JSON.parse(localStorage.getItem('sysPopupDismissed') || '[]');
    try {
        const popups = await apiFetch('/Settings/GetActivePopups?location=' + encodeURIComponent('landing'));
        if (!Array.isArray(popups) || !popups.length) return;
        const queue = popups.filter(function(p) { return dismissed.indexOf(p.id) === -1; });
        if (!queue.length) return;
        var idx = 0;
        function showNext() {
            if (idx >= queue.length) return;
            var p = queue[idx++];
            showLandingPopup(p, function() { setTimeout(showNext, 400); });
        }
        setTimeout(showNext, 800);
    } catch (e) { /* silent */ }

    function showLandingPopup(p, onClose) {
        var container = document.getElementById('sysPopupContainer');
        var el = document.createElement('div');
        el.className = 'sys-popup-overlay';
        var headCls = p.category === 'تنبيه' ? 'sys-popup-head-alert' : 'sys-popup-head-ad';
        var catBiIcon = p.category === 'تنبيه' ? 'bi-exclamation-triangle-fill' : 'bi-megaphone-fill';
        var bodyHtml = '';
        if (p.contentType === 'text') {
            bodyHtml = '<p style="color:#374151;font-size:14px;line-height:1.75;margin:0;">' + escHtml(p.textContent || '') + '</p>';
        } else if (p.contentType === 'image' && p.attachmentUrl) {
            var imgU = typeof appResolveUrl === 'function' ? appResolveUrl(p.attachmentUrl) : p.attachmentUrl;
            bodyHtml = '<img src="' + imgU + '" style="width:100%;border-radius:10px;object-fit:cover;max-height:220px;" />';
        } else if (p.contentType === 'video' && p.attachmentUrl) {
            var vidU = typeof appResolveUrl === 'function' ? appResolveUrl(p.attachmentUrl) : p.attachmentUrl;
            bodyHtml = '<video src="' + vidU + '" controls style="width:100%;border-radius:10px;"></video>';
        }
        el.innerHTML = '<div class="sys-popup-box">' +
            '<div class="' + headCls + '">' +
            '<div style="font-size:12px;font-weight:700;opacity:.9;margin-bottom:6px;display:flex;align-items:center;gap:5px;">' +
            '<i class="bi ' + catBiIcon + '" style="color:#fff;"></i><span style="color:#fff;">' + escHtml(p.category) + '</span></div>' +
            '<div style="font-weight:700;font-size:' + (p.titleFontSize || 18) + 'px;color:' + escHtml(p.titleColor || '#ffffff') + ';">' + escHtml(p.title) + '</div></div>' +
            '<div class="sys-popup-body">' + (bodyHtml || '<p style="color:#9CA3AF;font-size:13px;margin:0;">لا يوجد محتوى إضافي</p>') + '</div>' +
            '<div class="sys-popup-footer"><button type="button" class="sys-popup-close" id="sysPClose_' + p.id + '">إغلاق</button></div></div>';
        container.appendChild(el);
        function closePopup() {
            el.style.animation = 'lpFadeOut .2s ease forwards';
            setTimeout(function() { el.remove(); if (onClose) onClose(); }, 200);
            if (p.displayPeriod === 'once') {
                var d = JSON.parse(localStorage.getItem('sysPopupDismissed') || '[]');
                if (d.indexOf(p.id) === -1) { d.push(p.id); localStorage.setItem('sysPopupDismissed', JSON.stringify(d)); }
                apiFetch('/Settings/DismissPopup?id=' + p.id, 'POST').catch(function() {});
            }
        }
        document.getElementById('sysPClose_' + p.id).addEventListener('click', closePopup);
        el.addEventListener('click', function(e) { if (e.target === el) closePopup(); });
    }
    function escHtml(s) {
        if (!s) return '';
        var d = document.createElement('div'); d.textContent = String(s); return d.innerHTML;
    }
});

window.addEventListener('scroll', function() {
    var nav = document.getElementById('lpNav');
    if (window.scrollY > 20) nav.classList.add('scrolled');
    else nav.classList.remove('scrolled');
});

var reveals = document.querySelectorAll('.reveal');
var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
        if (entry.isIntersecting) {
            entry.target.classList.add('visible');
        }
    });
}, { threshold: 0.15 });

reveals.forEach(function(el) { observer.observe(el); });
</script>
</body>

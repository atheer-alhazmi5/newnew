@{
    ViewBag.Title = "مساحات العمل";
    ViewBag.PageName = "مساحات العمل";
}

<style>

.bnf-page-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:28px; flex-wrap:wrap; gap:12px; }
.bnf-section-title { font-weight:800; font-size:16px; color:var(--sa-800); margin:0 0 18px 0; padding-bottom:12px; border-bottom:2px solid var(--sa-100); display:flex; align-items:center; gap:8px; }
.bnf-section-title i { font-size:18px; color:var(--sa-600); }
.bnf-modal-footer { padding:20px 28px; display:flex; flex-wrap:wrap; gap:12px; border:none; justify-content:space-between; align-items:center; background:var(--gray-50); }
.bnf-save-btn { padding:12px 32px; border-radius:12px; font-size:15px; font-weight:700; font-family:'Cairo',sans-serif; border:none; cursor:pointer; background:var(--sa-600); color:#fff; }
.bnf-save-btn:hover { background:var(--sa-700); transform:translateY(-1px); }
.bnf-cancel-btn { padding:12px 32px; border-radius:12px; font-size:15px; font-weight:700; font-family:'Cairo',sans-serif; border:none; cursor:pointer; background:#6b7280; color:#fff; }
.bnf-cancel-btn:hover { background:#4b5563; }


.cls-action-btn { min-width:80px; border-radius:10px; font-weight:700; padding:7px 14px; font-size:12px; line-height:1.3; display:inline-flex; align-items:center; gap:5px; justify-content:center; cursor:pointer; transition:all .15s; border:2px solid transparent; font-family:'Cairo',sans-serif; white-space:nowrap; }
.cls-action-btn-detail { border-color:var(--info-500); color:var(--info-500); background:#fff; }
.cls-action-btn-detail:hover { background:var(--info-50); }
.cls-action-btn-edit { border-color:var(--sa-600); color:var(--sa-600); background:#fff; }
.cls-action-btn-edit:hover { background:var(--sa-50); }
.cls-action-btn-delete { border-color:var(--error-500); color:var(--error-500); background:#fff; }
.cls-action-btn-delete:hover { background:var(--error-50); }
.table .cls-action-btn { background-image:none; box-shadow:none; }
.ws-modal { border-radius:20px; border:none; overflow:hidden; box-shadow:0 20px 60px rgba(0,0,0,.15); }
.ws-modal-header { background:var(--sa-800); padding:24px 28px; position:relative; }
.ws-modal-header.info { background:var(--info-700); }
.ws-modal-header.delete { background:var(--error-600); }
.ws-modal-header .btn-close-x { position:absolute; top:16px; left:16px; background:none; border:none; color:rgba(255,255,255,.7); font-size:22px; cursor:pointer; }
.ws-modal-header .btn-close-x:hover { color:#fff; }
.ws-modal-title { color:#fff; font-weight:800; font-size:20px; margin:0; }
.ws-modal-subtitle { color:rgba(255,255,255,.7); font-size:14px; margin-top:4px; }
.ws-modal-body { padding:28px; max-height:75vh; overflow-y:auto; }
.required-star { color:#ef4444; margin-right:4px; }
.ws-status-pill { display:inline-flex; align-items:center; gap:6px; padding:6px 14px; border-radius:999px; font-weight:700; font-size:12px; }
.ws-status-pill.on { background:#dcf5e8; color:#0f9f5c; }
.ws-status-pill.off { background:#fde8e8; color:#b91c1c; }
.ws-status-dot { width:8px; height:8px; border-radius:999px; display:inline-block; }
.ws-status-pill.on .ws-status-dot { background:#0f9f5c; }
.ws-status-pill.off .ws-status-dot { background:#b91c1c; }
.ws-color-circle { width:28px; height:28px; border-radius:50%; display:inline-block; border:2px solid rgba(0,0,0,.1); vertical-align:middle; box-shadow:0 1px 4px rgba(0,0,0,.08); }
.ws-detail-row { display:flex; align-items:flex-start; gap:12px; padding:14px 0; border-bottom:1px solid var(--gray-100); }
.ws-detail-row:last-child { border-bottom:none; }
.ws-detail-label { font-weight:700; font-size:14px; color:var(--gray-600); min-width:120px; }
.ws-detail-value { font-size:14px; color:var(--gray-900); flex:1; }
.ws-color-picker-wrap { position:relative; display:inline-block; }
.ws-color-picker-wrap input[type="color"] { width:52px; height:52px; border:2px solid var(--gray-200); border-radius:14px; cursor:pointer; padding:3px; background:#fff; transition:border-color .2s; }
.ws-color-picker-wrap input[type="color"]:hover { border-color:var(--sa-400); }
.ws-color-picker-wrap input[type="color"]::-webkit-color-swatch-wrapper { padding:2px; }
.ws-color-picker-wrap input[type="color"]::-webkit-color-swatch { border-radius:10px; border:none; }
.ws-color-hex { font-size:13px; color:var(--gray-500); font-weight:600; direction:ltr; text-align:center; font-family:'Courier New',monospace; background:var(--gray-50); padding:4px 10px; border-radius:8px; border:1px solid var(--gray-200); }
.ws-modal-body .form-control, .ws-modal-body .form-select { border-radius:10px; border:2px solid var(--gray-200); padding:10px 14px; transition:border-color .2s, box-shadow .2s; }
.ws-modal-body .form-control:focus { border-color:var(--sa-400); box-shadow:0 0 0 3px rgba(37,147,95,.1); }
.ws-modal-body .form-label { font-weight:700; font-size:14px; color:var(--gray-700); margin-bottom:8px; }
.ws-modal-body .form-check-input:checked { background-color:var(--sa-600); border-color:var(--sa-600); }

</style>

<div class="bnf-page-header">
    <div>
        <h2 class="page-title" style="margin:0;">مساحات العمل</h2>
        <p style="color:var(--gray-500);font-size:14px;margin:6px 0 0;">نظم نماذجك في مساحات العمل</p>
    </div>
    <button type="button" class="btn btn-primary" onclick="wsShowAddModal()" style="border-radius:12px;padding:10px 28px;">
        <i class="bi bi-plus-lg"></i> إنشاء مساحة عمل
    </button>
</div>

<div class="d-flex gap-3 mb-4 flex-wrap align-items-center rt-filters" id="wsFiltersWrap">
    <div class="rt-search-box" style="min-width:200px;max-width:280px;">
        <i class="bi bi-search rt-search-icon"></i>
        <input type="text" class="form-control" id="wsFilterSearch" placeholder="بحث بالاسم أو الوصف..." autocomplete="off">
    </div>
    <select class="rt-filter-select form-select" id="wsFilterStatus" style="min-width:160px;">
        <option value="">الحالة</option>
        <option value="1">مفعل</option>
        <option value="0">غير مفعل</option>
    </select>
    <button type="button" class="rt-clear-btn" id="wsFilterClear" title="مسح الفلاتر"><i class="bi bi-x-circle"></i> مسح</button>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th style="width:60px;">الترتيب</th>
                        <th>مساحة العمل</th>
                        <th>الوصف</th>
                        <th style="width:140px;">اللون</th>
                        <th style="width:130px;">الحالة</th>
                        <th style="width:260px;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody id="wsBody">
                    <tr><td colspan="6" class="text-center py-4"><div class="spinner-border" style="color:var(--sa-600);"></div></td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="wsPaginationContainer" class="d-flex justify-content-center mt-4"></div>

<!-- إضافة -->
<div class="modal fade" id="wsAddModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content ws-modal">
            <div class="ws-modal-header">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="ws-modal-title"><i class="bi bi-plus-circle" style="margin-left:8px;"></i> إنشاء مساحة عمل</h5>
                <div class="ws-modal-subtitle">أدخل بيانات مساحة العمل الجديدة</div>
            </div>
            <div class="ws-modal-body">
                <div class="bnf-section-title"><i class="bi bi-grid-1x2"></i> بيانات مساحة العمل</div>
                <div class="mb-3">
                    <label class="form-label">اسم مساحة العمل<span class="required-star">*</span></label>
                    <input type="text" class="form-control" id="wsAddName" maxlength="200" autocomplete="off">
                </div>
                <div class="mb-3">
                    <label class="form-label">الوصف</label>
                    <textarea class="form-control" id="wsAddDescription" rows="3" placeholder="وصف اختياري"></textarea>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">اللون</label>
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <div class="ws-color-picker-wrap">
                                <input type="color" id="wsAddColor" value="#25935F" oninput="document.getElementById('wsAddColorHex').textContent=this.value">
                            </div>
                            <div class="ws-color-hex" id="wsAddColorHex" style="margin-top:0;">#25935F</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">الحالة</label>
                        <div class="d-flex align-items-center gap-3 mt-2">
                            <div class="form-check form-switch m-0">
                                <input class="form-check-input" type="checkbox" id="wsAddIsActive" checked style="width:48px;height:24px;">
                            </div>
                            <label class="form-check-label" for="wsAddIsActive" id="wsAddIsActiveLabel" style="font-weight:600;">مفعل</label>
                        </div>
                    </div>
                </div>
                <div id="wsAddError" class="alert alert-danger d-none" style="font-size:14px;"></div>
            </div>
            <div class="bnf-modal-footer" style="justify-content:flex-end;">
                <div style="display:flex; gap:10px;">
                    <button type="button" class="bnf-save-btn" onclick="wsSubmitAdd()"><i class="bi bi-plus-lg"></i> إضافة</button>
                    <button type="button" class="bnf-cancel-btn" data-bs-dismiss="modal">إلغاء</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- تحديث -->
<div class="modal fade" id="wsEditModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content ws-modal">
            <div class="ws-modal-header">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="ws-modal-title"><i class="bi bi-pencil-square" style="margin-left:8px;"></i> تحديث مساحة العمل</h5>
                <div class="ws-modal-subtitle">تعديل بيانات المساحة</div>
            </div>
            <div class="ws-modal-body">
                <input type="hidden" id="wsEditId">
                <div class="bnf-section-title"><i class="bi bi-grid-1x2"></i> بيانات مساحة العمل</div>
                <div class="mb-3">
                    <label class="form-label">اسم مساحة العمل<span class="required-star">*</span></label>
                    <input type="text" class="form-control" id="wsEditName" maxlength="200" autocomplete="off">
                </div>
                <div class="mb-3">
                    <label class="form-label">الوصف</label>
                    <textarea class="form-control" id="wsEditDescription" rows="3"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">الترتيب</label>
                    <input type="number" class="form-control" id="wsEditSortOrder" min="1" value="1">
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">اللون</label>
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <div class="ws-color-picker-wrap">
                                <input type="color" id="wsEditColor" value="#25935F" oninput="document.getElementById('wsEditColorHex').textContent=this.value">
                            </div>
                            <div class="ws-color-hex" id="wsEditColorHex" style="margin-top:0;">#25935F</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">الحالة</label>
                        <div class="d-flex align-items-center gap-3 mt-2">
                            <div class="form-check form-switch m-0">
                                <input class="form-check-input" type="checkbox" id="wsEditIsActive" style="width:48px;height:24px;">
                            </div>
                            <label class="form-check-label" for="wsEditIsActive" id="wsEditIsActiveLabel" style="font-weight:600;">مفعل</label>
                        </div>
                    </div>
                </div>
                <div id="wsEditError" class="alert alert-danger d-none" style="font-size:14px;"></div>
            </div>
            <div class="bnf-modal-footer" style="justify-content:flex-end;">
                <div style="display:flex; gap:10px;">
                    <button type="button" class="bnf-save-btn" onclick="wsSubmitEdit()"><i class="bi bi-check-lg"></i> حفظ التعديلات</button>
                    <button type="button" class="bnf-cancel-btn" data-bs-dismiss="modal">إلغاء</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- تفاصيل -->
<div class="modal fade" id="wsDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content ws-modal">
            <div class="ws-modal-header info">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="ws-modal-title"><i class="bi bi-eye" style="margin-left:8px;"></i> تفاصيل مساحة العمل</h5>
                <div class="ws-modal-subtitle">عرض البيانات</div>
            </div>
            <div class="ws-modal-body" id="wsDetailsBody"></div>
            <div class="bnf-modal-footer" style="justify-content:flex-end;">
                <button type="button" class="bnf-cancel-btn" data-bs-dismiss="modal">إغلاق</button>
            </div>
        </div>
    </div>
</div>

<!-- حذف -->
<div class="modal fade" id="wsDeleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content ws-modal">
            <div class="ws-modal-header delete">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="ws-modal-title"><i class="bi bi-trash3" style="margin-left:8px;"></i> حذف مساحة العمل</h5>
            </div>
            <div class="ws-modal-body text-center">
                <input type="hidden" id="wsDeleteId">
                <p style="font-weight:700;font-size:16px;margin-top:8px;color:var(--gray-800);">هل أنت متأكد من حذف مساحة العمل؟</p>
                <p style="font-size:14px;color:var(--gray-500);" id="wsDeleteNameLabel"></p>
                <div id="wsDeleteError" class="alert alert-danger d-none" style="font-size:14px;text-align:right;"></div>
            </div>
            <div class="bnf-modal-footer" style="justify-content:center;">
                <button type="button" class="bnf-save-btn" style="background:var(--error-600);" onclick="wsSubmitDelete()">نعم، حذف</button>
                <button type="button" class="bnf-cancel-btn" data-bs-dismiss="modal">إلغاء</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/workspaces.js?v=@DateTime.Now.Ticks"></script>
}

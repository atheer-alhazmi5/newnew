@{
    ViewBag.Title = "التفويضات";
    ViewBag.PageName = "التفويضات";
}

<style>
.bnf-modal { border-radius:16px; border:none; overflow:hidden; box-shadow:0 8px 50px rgba(0,0,0,.2); }
.bnf-modal-header { background:var(--info-700); padding:18px 24px; position:relative; }
.bnf-modal-header .btn-close-x { position:absolute; top:14px; left:14px; background:none; border:none; color:rgba(255,255,255,.7); font-size:18px; cursor:pointer; }
.bnf-modal-header .btn-close-x:hover { color:#fff; }
.bnf-modal-title { color:#fff; font-weight:700; font-size:16px; margin:0; }
.bnf-modal-body { padding:24px; max-height:75vh; overflow-y:auto; }
.bnf-modal-footer { padding:16px 24px; border:none; justify-content:flex-end; background:var(--gray-50); border-top:1px solid var(--gray-100); }
.bnf-cancel-btn { padding:9px 24px; border-radius:10px; font-size:13px; font-weight:700; border:none; cursor:pointer; background:#6b7280; color:#fff; }
.bnf-page-header { margin-bottom:24px; }
.bnf-tbl .table-responsive { overflow-x:auto; max-width:100%; }
.bnf-tbl .table { width:100%; margin-bottom:0; min-width:880px; font-size:13px; }
</style>

<div class="bnf-settings-page">
    <div class="bnf-page-header">
        <h2 class="page-title" style="margin:0;">التفويضات</h2>
        <p style="color:var(--gray-500);font-size:14px;margin:8px 0 0;">التفويضات التي تشارك فيها كمفوِّض أو مفوَّض له، مع الصلاحية المعروضة لكل طرف.</p>
    </div>

    <div class="card bnf-tbl">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th style="width:40px;">#</th>
                            <th>المفوض</th>
                            <th>وحدة المفوض</th>
                            <th>المفوض له</th>
                            <th>وحدة المفوض له</th>
                            <th>البداية</th>
                            <th>النهاية</th>
                            <th>الحالة</th>
                            <th style="width:72px;">تفاصيل</th>
                        </tr>
                    </thead>
                    <tbody id="myDelBody">
                        <tr><td colspan="9" class="text-center py-4"><div class="spinner-border" style="color:var(--sa-600);"></div></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="myDelDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content bnf-modal">
            <div class="bnf-modal-header">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="bnf-modal-title"><i class="bi bi-eye" style="margin-left:8px;"></i>تفاصيل التفويض</h5>
            </div>
            <div class="bnf-modal-body" id="myDelDetailsBody"></div>
            <div class="bnf-modal-footer">
                <button type="button" class="bnf-cancel-btn" data-bs-dismiss="modal">إغلاق</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/my-delegations.js?v=@DateTime.Now.Ticks"></script>
}

                        <th style="text-align:center;">الحالة</th>
                        <th style="text-align:center;display:none;" id="wpThActive">التفعيل</th>
                        <th style="text-align:center;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody id="wpBody">

<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
    <div>
        <h2 class="page-title mb-0">إجراءات العمل</h2>
        <p style="color:var(--gray-500);font-size:14px;margin:6px 0 0;">إنشاء وإدارة إجراءات العمل في النظام</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <button type="button" class="btn btn-outline-primary" onclick="wpShowVersionMode()" style="border-radius:12px;padding:10px 24px;font-weight:700;">
            <i class="bi bi-layers"></i> إصدار نسخة
        </button>
        <button type="button" class="btn btn-primary" onclick="wpShowCreate()" style="border-radius:12px;padding:10px 28px;">
            <i class="bi bi-plus-lg"></i> إنشاء إجراء عمل جديد
        </button>
    </div>
</div>

<div class="d-flex gap-3 mb-4 flex-wrap align-items-center rt-filters wp-procedure-filters">
    <div class="rt-search-box">
        <i class="bi bi-search rt-search-icon"></i>
        <input type="text" class="form-control" id="wpSearch" placeholder="بحث في أسماء الإجراء..." oninput="wpLoad()">
    </div>
    <select class="rt-filter-select form-select" id="wpFilterWorkspace" onchange="wpLoad()" aria-label="مساحة العمل">
        <option value="">مساحة العمل</option>
    </select>
    <select class="rt-filter-select form-select" id="wpFilterFormDef" onchange="wpLoad()" aria-label="النماذج المستخدمة">
        <option value="">النماذج المستخدمة</option>
    </select>
    <select class="rt-filter-select form-select" id="wpFilterValidity" onchange="wpLoad()" aria-label="صلاحية الإجراء">
        <option value="">صلاحية الإجراء</option>
        <option value="دائم">دائم</option>
        <option value="مؤقت">مؤقت</option>
    </select>
    <div class="wp-filt-ou-wrap">
        <input type="hidden" id="wpFilterTargetOrg" value="">
        <button type="button" class="form-select rt-filter-select text-end w-100 wp-filt-ou-tree-trigger" id="wpFilterOuTrigger" aria-expanded="false" aria-haspopup="listbox" title="تصفية حسب الوحدة التنظيمية المستهدفة">
            <span class="wp-filt-ou-tree-label text-truncate d-block" id="wpFilterOuLabel">الوحدات التنظيمية المستهدفة</span>
        </button>
        <div class="wp-filt-ou-tree-panel d-none" id="wpFilterOuPanel" role="listbox" style="position:absolute;left:0;right:0;top:100%;margin-top:4px;z-index:1060;"></div>
    </div>
    <select class="rt-filter-select form-select" id="wpFilterExecutor" onchange="wpLoad()" aria-label="المنفذ للإجراء">
        <option value="">المنفذ للإجراء</option>
    </select>
    <select class="rt-filter-select form-select" id="wpFilterStatus" onchange="wpLoad()" aria-label="الحالة">
        <option value="">الحالة</option>
        <option value="draft">مسودة</option>
        <option value="pending">بانتظار الاعتماد</option>
        <option value="approved">معتمد</option>
        <option value="rejected">مرفوض</option>
    </select>
    <select class="rt-filter-select form-select" id="wpFilterActive" onchange="wpLoad()" aria-label="التفعيل">
        <option value="">التفعيل</option>
        <option value="1">مفعل</option>
        <option value="0">غير مفعل</option>
    </select>
    <button type="button" class="rt-clear-btn" onclick="wpClear()"><i class="bi bi-x-circle"></i> مسح</button>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0" id="wpTable">
                <thead>

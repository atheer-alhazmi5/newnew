@{
    ViewBag.Title = "التفويضات";
    ViewBag.PageName = "التفويضات";
}

<style>

.dlg-modal { border-radius:16px; border:none; overflow:hidden; box-shadow:0 8px 50px rgba(0,0,0,.2); }
.dlg-modal-header { background:var(--sa-700); padding:18px 24px; position:relative; }
.dlg-modal-header.edit { background:var(--sa-800); }
.dlg-modal-header.details { background:var(--info-700); }
.dlg-modal-header.delete { background:var(--error-600); }
.dlg-modal-header .btn-close-x { position:absolute; top:14px; left:14px; background:none; border:none; color:rgba(255,255,255,.7); font-size:18px; cursor:pointer; }
.dlg-modal-header .btn-close-x:hover { color:#fff; }
.dlg-modal-title { color:#fff; font-weight:700; font-size:16px; margin:0; }
.dlg-modal-subtitle { color:rgba(255,255,255,.7); font-size:12px; margin-top:2px; }
.dlg-modal-body { padding:24px; max-height:75vh; overflow-y:auto; }
.dlg-modal-footer { padding:16px 24px; display:flex; flex-wrap:wrap; gap:10px; border:none; justify-content:space-between; align-items:center; background:var(--gray-50); border-top:1px solid var(--gray-100); }
.dlg-save-btn { padding:11px 28px; border-radius:12px; font-size:14px; font-weight:700; font-family:'Cairo',sans-serif; border:none; cursor:pointer; color:#fff; transition:all .15s; display:inline-flex; align-items:center; gap:8px; }
.dlg-save-btn:hover { transform:translateY(-1px); }
.dlg-save-btn.draft { background:var(--gray-500); }
.dlg-save-btn.draft:hover { background:var(--gray-600); }
.dlg-save-btn.send  { background:var(--sa-600); }
.dlg-save-btn.send:hover  { background:var(--sa-700); }
.dlg-cancel-btn { padding:11px 28px; border-radius:12px; font-size:14px; font-weight:700; font-family:'Cairo',sans-serif; border:none; cursor:pointer; background:#6b7280; color:#fff; transition:all .15s; }
.dlg-cancel-btn:hover { background:#4b5563; }
.dlg-revoke-btn { padding:9px 22px; border-radius:10px; font-size:13px; font-weight:700; font-family:'Cairo',sans-serif; border:2px solid var(--error-500); background:#fff; color:var(--error-600); cursor:pointer; transition:all .15s; }
.dlg-revoke-btn:hover { background:var(--error-50); }

.dlg-section { background:#fff; border-radius:12px; padding:18px 20px; margin-bottom:16px; border:1px solid var(--gray-200); }
.dlg-section-title { font-weight:700; font-size:14px; color:var(--sa-800); margin:0 0 14px 0; padding-bottom:10px; border-bottom:2px solid var(--sa-100); display:flex; align-items:center; gap:8px; }
.dlg-section-title i { font-size:15px; color:var(--sa-600); }
.required-star { color:#ef4444; margin-right:4px; }

.dlg-form-row { display:grid; grid-template-columns:repeat(2,1fr); gap:14px; margin-bottom:14px; }
.dlg-form-row:last-child { margin-bottom:0; }

.dlg-action-btn { min-width:auto; border-radius:8px; font-weight:700; padding:5px 10px; font-size:11px; line-height:1.3; display:inline-flex; align-items:center; gap:4px; justify-content:center; cursor:pointer; transition:all .15s; border:2px solid transparent; font-family:'Cairo',sans-serif; white-space:nowrap; background:transparent; }
.dlg-action-btn-detail { border-color:var(--info-500); color:var(--info-500); background:#fff; }
.dlg-action-btn-detail:hover { background:var(--info-50); }
.dlg-action-btn-edit { border-color:var(--sa-600); color:var(--sa-600); background:#fff; }
.dlg-action-btn-edit:hover { background:var(--sa-50); }
.dlg-action-btn-delete { border-color:var(--error-500); color:var(--error-500); background:#fff; }
.dlg-action-btn-delete:hover { background:var(--error-50); }

/* OU tree (filters + form) — نفس نمط المستفيدين */
.dlg-ou-tree-trigger { text-align:right !important; cursor:pointer; background-color:#fff; display:flex; align-items:center; min-height:calc(1.5em + 0.75rem + 2px); }
.dlg-ou-tree-label { font-weight:500; color:var(--gray-800); }
.dlg-ou-tree-panel { max-height:280px; overflow-y:auto; background:#fff; border:1px solid var(--gray-300); border-radius:8px; margin-top:4px; box-shadow:0 4px 16px rgba(0,0,0,.08); }
.dlg-ou-tree-row { user-select:none; border-bottom:1px solid var(--gray-100); transition:background .15s ease; gap:8px; }
.dlg-ou-tree-row:hover { background:var(--sa-25); }
.dlg-ou-tree-row.is-selected { background:var(--info-50); }
.dlg-ou-tree-exp { flex-shrink:0; width:1.35rem; height:1.35rem; min-width:1.35rem; padding:0; line-height:1; font-weight:600; font-size:11px; color:var(--sa-600); border:1px solid var(--gray-200); border-radius:8px; background:linear-gradient(180deg,#fff 0%,#fafafa 100%); cursor:pointer; display:inline-flex; align-items:center; justify-content:center; box-shadow:0 1px 2px rgba(0,0,0,.04); transition:background .15s ease,border-color .15s ease; }
.dlg-ou-tree-exp:hover { background:var(--sa-50); border-color:var(--sa-300); color:var(--sa-700); }
.dlg-ou-tree-exp-spacer { flex-shrink:0; width:1.35rem; height:1.35rem; min-width:1.35rem; }
.dlg-ou-tree-name { text-align:right; font-size:14px; line-height:1.4; min-width:0; }

/* شارات الحالة */
.dlg-status-pill { display:inline-flex; align-items:center; gap:6px; padding:5px 12px; border-radius:999px; font-weight:700; font-size:11px; white-space:nowrap; }
.dlg-status-dot { width:7px; height:7px; border-radius:999px; display:inline-block; }
.dlg-status-draft     { background:var(--gray-100);  color:var(--gray-700); }
.dlg-status-draft     .dlg-status-dot { background:var(--gray-400); }
.dlg-status-scheduled { background:#e0f2fe; color:#0369a1; }
.dlg-status-scheduled .dlg-status-dot { background:#0284c7; }
.dlg-status-active    { background:#dcf5e8; color:#0f9f5c; }
.dlg-status-active    .dlg-status-dot { background:#0f9f5c; }
.dlg-status-expired   { background:#fff6ed; color:#b93815; }
.dlg-status-expired   .dlg-status-dot { background:#f59e0b; }
.dlg-status-cancelled { background:#fde8e8; color:#ef4444; }
.dlg-status-cancelled .dlg-status-dot { background:#ef4444; }

.dlg-page-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:28px; flex-wrap:wrap; gap:12px; }
.dlg-tbl .table { font-size:13px; }
.dlg-tbl .table thead th { font-size:12px; white-space:nowrap; padding:10px 8px; vertical-align:middle; }
.dlg-tbl .table tbody td { padding:8px; vertical-align:middle; white-space:nowrap; }

.dlg-detail-row { display:grid; grid-template-columns:minmax(140px,180px) 1fr; gap:12px; padding:12px 0; border-bottom:1px solid var(--gray-100); align-items:start; }
.dlg-detail-label { font-weight:700; color:var(--gray-600); font-size:13px; }
.dlg-detail-value { font-size:14px; color:var(--gray-800); word-break:break-word; }

@@media (max-width:768px) { .dlg-form-row { grid-template-columns:1fr; } }
</style>

<!-- Header -->
<div class="dlg-page-header">
    <div>
        <h2 class="page-title" style="margin:0;">إدارة التفويضات</h2>
        <p style="color:var(--gray-500);font-size:14px;margin:6px 0 0;">تفويض الصلاحيات مؤقتاً للمستخدمين الآخرين</p>
    </div>
    <button class="btn btn-primary" onclick="dlgShowAddModal()" style="border-radius:12px;padding:10px 28px;font-weight:700;font-size:14px;display:inline-flex;align-items:center;gap:8px;">
        <i class="bi bi-plus-lg"></i> إضافة تفويض
    </button>
</div>

<!-- Filters -->
<div class="d-flex gap-3 mb-4 flex-wrap align-items-center rt-filters" id="dlgFiltersWrap">
    <div class="rt-search-box" style="min-width:220px;max-width:320px;">
        <i class="bi bi-search rt-search-icon"></i>
        <input type="text" class="form-control" id="dlgFilterSearch" placeholder="بحث باسم المفوض أو المفوض له..." autocomplete="off">
    </div>

    <div class="dlg-filter-ou-wrap" style="min-width:220px;max-width:260px;position:relative;" data-wrap="dor">
        <input type="hidden" id="dlgFilterDorUnit" value="">
        <button type="button" class="form-select rt-filter-select text-end w-100 dlg-ou-tree-trigger" id="dlgFilterDorTrigger" aria-expanded="false" aria-haspopup="listbox" title="الوحدة التنظيمية للمفوض">
            <span class="dlg-ou-tree-label text-truncate d-block" id="dlgFilterDorLabel">وحدة المفوِض</span>
        </button>
        <div class="dlg-ou-tree-panel d-none" id="dlgFilterDorPanel" role="listbox" style="position:absolute;left:0;right:0;top:100%;margin-top:4px;z-index:1060;"></div>
    </div>

    <div class="dlg-filter-ou-wrap" style="min-width:220px;max-width:260px;position:relative;" data-wrap="dee">
        <input type="hidden" id="dlgFilterDeeUnit" value="">
        <button type="button" class="form-select rt-filter-select text-end w-100 dlg-ou-tree-trigger" id="dlgFilterDeeTrigger" aria-expanded="false" aria-haspopup="listbox" title="الوحدة التنظيمية للمفوَض له">
            <span class="dlg-ou-tree-label text-truncate d-block" id="dlgFilterDeeLabel">وحدة المفوض له</span>
        </button>
        <div class="dlg-ou-tree-panel d-none" id="dlgFilterDeePanel" role="listbox" style="position:absolute;left:0;right:0;top:100%;margin-top:4px;z-index:1060;"></div>
    </div>

    <button type="button" class="rt-clear-btn" id="dlgFilterClear" title="مسح الفلاتر"><i class="bi bi-x-circle"></i> مسح</button>
</div>

<!-- Table -->
<div class="card dlg-tbl">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th style="width:60px;text-align:center;">الترتيب</th>
                        <th>المفوِض</th>
                        <th>الوحدة التنظيمية للمفوِض</th>
                        <th>المفوض له</th>
                        <th>الوحدة التنظيمية للمفوَض له</th>
                        <th style="width:120px;">تاريخ البداية</th>
                        <th style="width:120px;">تاريخ النهاية</th>
                        <th style="width:110px;">الحالة</th>
                        <th style="width:220px;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody id="dlgBody">
                    <tr><td colspan="9" class="text-center py-4"><div class="spinner-border" style="color:var(--sa-600);"></div></td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="dlgFormModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content dlg-modal">
            <div class="dlg-modal-header" id="dlgModalHeader">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="dlg-modal-title" id="dlgModalTitle"><i class="bi bi-plus-circle" style="margin-left:8px;"></i>إضافة تفويض</h5>
                <div class="dlg-modal-subtitle" id="dlgModalSubtitle">أدخل بيانات التفويض</div>
            </div>
            <div class="dlg-modal-body">
                <input type="hidden" id="dlgId">

                <!-- المفوِّض -->
                <div class="dlg-section">
                    <div class="dlg-section-title"><i class="bi bi-person-fill-gear"></i>المفوِض</div>
                    <div class="dlg-form-row">
                        <div>
                            <label class="form-label">الوحدة التنظيمية للمفوض<span class="required-star">*</span></label>
                            <div style="position:relative;" data-wrap="f-dor">
                                <input type="hidden" id="dlgFormDorUnit" value="">
                                <button type="button" class="form-select dlg-ou-tree-trigger text-end w-100" id="dlgFormDorTrigger" aria-expanded="false" aria-haspopup="listbox">
                                    <span class="dlg-ou-tree-label text-truncate d-block" id="dlgFormDorLabel">-- اختر --</span>
                                </button>
                                <div class="dlg-ou-tree-panel d-none" id="dlgFormDorPanel" role="listbox" style="position:absolute;left:0;right:0;top:100%;margin-top:4px;z-index:1070;"></div>
                            </div>
                        </div>
                        <div>
                            <label class="form-label">المفوِض<span class="required-star">*</span></label>
                            <select class="form-select" id="dlgFormDor">
                                <option value="">-- اختر الوحدة أولاً --</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="dlg-section">
                    <div class="dlg-section-title"><i class="bi bi-person-check-fill"></i>المفوض له</div>
                    <div class="dlg-form-row">
                        <div>
                            <label class="form-label">الوحدة التنظيمية للمفوض له<span class="required-star">*</span></label>
                            <div style="position:relative;" data-wrap="f-dee">
                                <input type="hidden" id="dlgFormDeeUnit" value="">
                                <button type="button" class="form-select dlg-ou-tree-trigger text-end w-100" id="dlgFormDeeTrigger" aria-expanded="false" aria-haspopup="listbox">
                                    <span class="dlg-ou-tree-label text-truncate d-block" id="dlgFormDeeLabel">-- اختر --</span>
                                </button>
                                <div class="dlg-ou-tree-panel d-none" id="dlgFormDeePanel" role="listbox" style="position:absolute;left:0;right:0;top:100%;margin-top:4px;z-index:1070;"></div>
                            </div>
                        </div>
                        <div>
                            <label class="form-label">المفوض له<span class="required-star">*</span></label>
                            <select class="form-select" id="dlgFormDee">
                                <option value="">-- اختر الوحدة أولاً --</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- الفترة -->
                <div class="dlg-section">
                    <div class="dlg-section-title"><i class="bi bi-calendar-range"></i>فترة التفويض</div>
                    <div class="dlg-form-row">
                        <div>
                            <label class="form-label">تاريخ بداية التفويض<span class="required-star">*</span></label>
                            <input type="date" class="form-control" id="dlgFormStart">
                        </div>
                        <div>
                            <label class="form-label">تاريخ نهاية التفويض<span class="required-star">*</span></label>
                            <input type="date" class="form-control" id="dlgFormEnd">
                          
                        </div>
                    </div>
                </div>

                <div id="dlgFormError" class="alert alert-danger d-none" style="font-size:13px;"></div>
            </div>
            <div class="dlg-modal-footer" style="justify-content:space-between;">
                <div id="dlgEditRevokeWrap" style="display:none;">
                    <button type="button" class="dlg-revoke-btn" onclick="dlgRevoke()"><i class="bi bi-slash-circle"></i> إلغاء التفويض</button>
                </div>
                <div style="display:flex;gap:10px;flex-wrap:wrap;margin-inline-start:auto;">
                    <button type="button" class="dlg-save-btn draft" id="dlgSaveDraftBtn" onclick="dlgSubmit(true)"><i class="bi bi-floppy2-fill"></i> حفظ كمسودة</button>
                    <button type="button" class="dlg-save-btn send" id="dlgSaveBtn" onclick="dlgSubmit(false)"><i class="bi bi-check-lg"></i> حفظ</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Details Modal -->
<div class="modal fade" id="dlgDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content dlg-modal">
            <div class="dlg-modal-header details">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="dlg-modal-title"><i class="bi bi-eye" style="margin-left:8px;"></i>تفاصيل التفويض</h5>
                <div class="dlg-modal-subtitle">عرض جميع بيانات التفويض</div>
            </div>
            <div class="dlg-modal-body" id="dlgDetailsBody"></div>
            <div class="dlg-modal-footer" style="justify-content:flex-end;">
                <button class="dlg-cancel-btn" data-bs-dismiss="modal">إغلاق</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="dlgDeleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content dlg-modal">
            <div class="dlg-modal-header delete">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="dlg-modal-title">حذف التفويض</h5>
            </div>
            <div class="dlg-modal-body text-center">
                <input type="hidden" id="dlgDeleteId">
                <p style="font-weight:700;font-size:16px;margin-top:8px;color:var(--gray-800);">هل أنت متأكد من حذف هذا التفويض؟</p>
                <p style="font-size:13px;color:var(--gray-500);" id="dlgDeleteLabel"></p>
                <div id="dlgDeleteError" class="alert alert-danger d-none" style="font-size:13px;text-align:right;"></div>
            </div>
            <div class="dlg-modal-footer" style="justify-content:center;">
                <button class="dlg-save-btn" style="background:var(--error-600);" onclick="dlgSubmitDelete()">نعم، حذف</button>
                <button class="dlg-cancel-btn" data-bs-dismiss="modal">إلغاء</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/delegations.js?v=@DateTime.Now.Ticks"></script>
}

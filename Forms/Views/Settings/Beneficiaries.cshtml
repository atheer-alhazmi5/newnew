@{
    ViewBag.Title = "المستفيدين";
    ViewBag.PageName = "المستفيدين";
}

<style>
.bnf-modal { border-radius:16px; border:none; overflow:hidden; box-shadow:0 8px 50px rgba(0,0,0,.2); }
.bnf-modal-header { background:var(--sa-700); padding:18px 24px; position:relative; }
.bnf-modal-header .btn-close-x { position:absolute; top:14px; left:14px; background:none; border:none; color:rgba(255,255,255,.7); font-size:18px; cursor:pointer; }
.bnf-modal-header .btn-close-x:hover { color:#fff; }
.bnf-modal-title { color:#fff; font-weight:700; font-size:16px; margin:0; }
.bnf-modal-subtitle { color:rgba(255,255,255,.7); font-size:12px; margin-top:2px; }
.bnf-modal-body { padding:24px; max-height:75vh; overflow-y:auto; }
.bnf-modal-footer { padding:16px 24px; display:flex; flex-wrap:wrap; gap:10px; border:none; justify-content:space-between; align-items:center; background:var(--gray-50); border-top:1px solid var(--gray-100); }
.bnf-save-btn { padding:9px 24px; border-radius:10px; font-size:13px; font-weight:700; font-family:'Cairo',sans-serif; border:none; cursor:pointer; background:var(--sa-600); color:#fff; transition:all .15s; }
.bnf-save-btn:hover { background:var(--sa-700); }
.bnf-cancel-btn { padding:9px 24px; border-radius:10px; font-size:13px; font-weight:700; font-family:'Cairo',sans-serif; border:none; cursor:pointer; background:#6b7280; color:#fff; transition:all .15s; }
.bnf-cancel-btn:hover { background:#4b5563; }
.bnf-section { background:#fff; border-radius:12px; padding:18px 20px; margin-bottom:16px; border:1px solid var(--gray-200); }
.bnf-section-title { font-weight:700; font-size:14px; color:var(--sa-800); margin:0 0 14px 0; padding-bottom:10px; border-bottom:2px solid var(--sa-100); display:flex; align-items:center; gap:8px; }
.bnf-section-title i { font-size:15px; color:var(--sa-600); }
.required-star { color:#ef4444; margin-right:4px; }
.bnf-action-btn { min-width:70px; border-radius:8px; font-weight:700; padding:6px 12px; font-size:11.5px; line-height:1.3; display:inline-flex; align-items:center; gap:4px; justify-content:center; cursor:pointer; transition:all .15s; border:1.5px solid transparent; font-family:'Cairo',sans-serif; white-space:nowrap; box-sizing:border-box; background:transparent; }
.bnf-action-btn-detail { border-color:var(--info-500); color:var(--info-500); background:#fff; }
.bnf-action-btn-detail:hover { background:var(--info-50); }
.bnf-action-btn-edit { border-color:var(--sa-600); color:var(--sa-600); background:#fff; }
.bnf-action-btn-edit:hover { background:var(--sa-50); }
.bnf-action-btn-delete { border-color:var(--error-500); color:var(--error-500); background:#fff; }
.bnf-action-btn-delete:hover { background:var(--error-50); }
.bnf-form-row { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:14px; }
.bnf-form-row:last-child { margin-bottom:0; }
.bnf-form-row-2 { grid-template-columns:repeat(2,1fr); }
.bnf-form-row-3 { grid-template-columns:repeat(3,1fr); }
.bnf-photo-preview { width:80px; height:80px; border-radius:50%; object-fit:cover; border:2px solid var(--gray-200); background:var(--gray-100); }
.bnf-photo-wrap { display:flex; flex-direction:column; align-items:center; gap:6px; }
.bnf-page-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:28px; flex-wrap:wrap; gap:12px; width:100%; max-width:100%; box-sizing:border-box; }
.bnf-page-header > div:first-child { min-width:0; flex:1 1 auto; }
.bnf-page-header .btn-primary { flex-shrink:0; }
#bnfFiltersWrap { width:100%; max-width:100%; box-sizing:border-box; }
.bnf-settings-page { width:100%; max-width:100%; box-sizing:border-box; }
.bnf-tbl { width:100%; max-width:100%; min-width:0; box-sizing:border-box; }
.bnf-tbl .table-responsive { overflow-x:auto; -webkit-overflow-scrolling:touch; max-width:100%; }
.bnf-tbl .table { width:100%; margin-bottom:0; min-width:1040px; }
.bnf-sign-canvas { border:2px dashed var(--gray-300); border-radius:12px; background:var(--gray-50); cursor:crosshair; touch-action:none; }
.bnf-sign-canvas-wrap { display:flex; flex-direction:column; gap:8px; }
.bnf-sign-canvas-wrap .btn-sm { padding:6px 14px; font-size:12px; }
.bnf-attach-preview { max-width:120px; max-height:100px; border-radius:8px; object-fit:contain; border:1px solid var(--gray-300); }
.bnf-attach-preview-wrap { display:flex; flex-direction:column; gap:6px; align-items:flex-start; }
.bnf-activation-wrap { display:flex; align-items:center; gap:10px; padding:10px 16px; background:#fff; border-radius:10px; border:1px solid var(--gray-200); }
.bnf-activation-wrap .form-check-input { width:44px; height:22px; cursor:pointer; }
.bnf-activation-wrap .form-check-label { font-weight:700; font-size:13px; cursor:pointer; }
.bnf-pw-hint { margin-top:8px; padding:12px 14px; background:var(--gray-50); border:1px solid var(--gray-200); border-radius:10px; font-size:11.5px; line-height:1.55; color:var(--gray-700); }
.bnf-pw-hint-title { font-weight:700; font-size:12px; color:var(--sa-800); margin-bottom:6px; display:flex; align-items:center; gap:6px; }
.bnf-pw-hint-title i { color:var(--sa-600); font-size:14px; }
.bnf-pw-hint-note { font-weight:600; color:var(--gray-500); font-size:11px; margin-bottom:10px; }
.bnf-pw-hint-list { list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:4px; }
.bnf-pw-hint-list li { display:flex; align-items:center; gap:8px; margin:0; padding:5px 8px; border-radius:8px; transition:all .2s ease; }
.bnf-pw-hint-list li.pw-met { background:rgba(5,150,105,.06); }
.bnf-pw-req-icon { flex-shrink:0; width:20px; height:20px; display:flex; align-items:center; justify-content:center; border-radius:50%; font-size:12px; transition:all .25s ease; color:var(--gray-400); background:var(--gray-100); }
.bnf-pw-hint-list li.pw-met .bnf-pw-req-icon { color:#fff; background:#059669; }
.bnf-pw-hint-list strong { color:var(--gray-800); font-weight:700; }
.bnf-pw-hint-list li.pw-met strong { color:#059669; }
.bnf-pw-hint-chars { display:inline-block; direction:ltr; unicode-bidi:embed; font-family:'Consolas','Courier New',monospace; font-size:11px; padding:2px 6px; background:#fff; border:1px solid var(--gray-200); border-radius:6px; }
.bnf-ou-tree-trigger { text-align: right !important; cursor: pointer; background-color: #fff; display: flex; align-items: center; min-height: calc(1.5em + 0.75rem + 2px); }
.bnf-ou-tree-label { font-weight: 500; color: var(--gray-800); }
.bnf-ou-tree-panel { max-height: 280px; overflow-y: auto; background: #fff; border: 1px solid var(--gray-300); border-radius: 8px; margin-top: 8px; box-shadow: 0 4px 16px rgba(0,0,0,.08); }
.bnf-ou-tree-row { user-select: none; border-bottom: 1px solid var(--gray-100); transition: background .15s ease; gap: 8px; }
.bnf-ou-tree-row:hover { background: var(--sa-25); }
.bnf-ou-tree-row.is-selected { background: var(--info-50); }
.bnf-ou-tree-exp { flex-shrink: 0; width: 1.35rem; height: 1.35rem; min-width: 1.35rem; padding: 0; line-height: 1; font-weight: 600; font-size: 11px; color: var(--sa-600); border: 1px solid var(--gray-200); border-radius: 8px; background: linear-gradient(180deg,#fff 0%,#fafafa 100%); cursor: pointer; display: inline-flex; align-items: center; justify-content: center; text-decoration: none !important; box-shadow: 0 1px 2px rgba(0,0,0,.04); transition: background .15s ease, border-color .15s ease, box-shadow .15s ease, transform .12s ease; }
.bnf-ou-tree-exp:hover { background: var(--sa-50); border-color: var(--sa-300); box-shadow: 0 1px 3px rgba(37,147,95,.1); color: var(--sa-700); }
.bnf-ou-tree-exp:active { transform: scale(0.94); }
.bnf-ou-tree-exp-spacer { flex-shrink: 0; width: 1.35rem; height: 1.35rem; min-width: 1.35rem; }
.bnf-ou-tree-name { text-align: right; font-size: 14px; line-height: 1.4; min-width: 0; }
.bnf-tbl-avatar { width:32px; height:32px; border-radius:50%; object-fit:cover; border:2px solid var(--gray-200); background:var(--gray-100); vertical-align:middle; }
.bnf-tbl-avatar-placeholder { width:32px; height:32px; border-radius:50%; background:var(--gray-100); display:inline-flex; align-items:center; justify-content:center; border:2px solid var(--gray-200); color:var(--gray-400); font-size:14px; }
.bnf-tbl .table { font-size:13px; }
.bnf-tbl .table thead th { font-size:12px; white-space:nowrap; padding:10px 8px; vertical-align:middle; }
.bnf-tbl .table tbody td { padding:8px; vertical-align:middle; white-space:nowrap; }
.bnf-status-pill { display:inline-flex; align-items:center; gap:6px; padding:5px 12px; border-radius:999px; font-weight:700; font-size:11px; }
.bnf-status-pill.active { background:#dcf5e8; color:#0f9f5c; }
.bnf-status-pill.inactive { background:#fde8e8; color:#ef4444; }
.bnf-status-dot { width:7px; height:7px; border-radius:999px; display:inline-block; }
.bnf-status-pill.active .bnf-status-dot { background:#0f9f5c; }
.bnf-status-pill.inactive .bnf-status-dot { background:#ef4444; }
@@media (max-width:992px) { .bnf-form-row { grid-template-columns:repeat(2,1fr); } }
@@media (max-width:576px) { .bnf-form-row { grid-template-columns:1fr; } }
</style>

<div class="bnf-settings-page">
<div class="bnf-page-header">
    <div>
        <h2 class="page-title" style="margin:0;">المستفيدين</h2>
        <p style="color:var(--gray-500);font-size:14px;margin:6px 0 0;">إدارة المستفيدين والموظفين</p>
    </div>
    <button class="btn btn-primary" onclick="bnfShowAddModal()" style="border-radius:12px;padding:10px 28px;font-weight:700;font-size:14px;display:inline-flex;align-items:center;gap:8px;">
        <i class="bi bi-plus-lg"></i> إضافة مستفيد
    </button>
</div>

<div class="d-flex gap-3 mb-4 flex-wrap align-items-center rt-filters" id="bnfFiltersWrap">
    <div class="rt-search-box" style="min-width:200px;max-width:280px;">
        <i class="bi bi-search rt-search-icon"></i>
        <input type="text" class="form-control" id="bnfFilterName" placeholder="بحث باسم الموظف..." autocomplete="off">
    </div>
    <input type="text" class="form-control rt-filter-text" id="bnfFilterNationalId" placeholder="رقم الهوية" maxlength="10" inputmode="numeric" autocomplete="off" title="الهوية">
    <div class="bnf-filter-ou-wrap" style="min-width:220px;max-width:280px;position:relative;">
        <input type="hidden" id="bnfFilterUnit" value="">
        <button type="button" class="form-select rt-filter-select text-end w-100 bnf-ou-tree-trigger" id="bnfFilterOuTrigger" aria-expanded="false" aria-haspopup="listbox" title="تصفية حسب الوحدة التنظيمية">
            <span class="bnf-ou-tree-label text-truncate d-block" id="bnfFilterOuLabel">الوحدة التنظيمية</span>
        </button>
        <div class="bnf-ou-tree-panel d-none" id="bnfFilterOuPanel" role="listbox" style="position:absolute;left:0;right:0;top:100%;margin-top:4px;z-index:1060;max-height:min(320px,70vh);"></div>
    </div>
    <select class="rt-filter-select form-select" id="bnfFilterSubRole" style="min-width:220px;">
        <option value="">الدور الفرعي</option>
        <option value="__employee__">الموظف</option>
        <option value="__unit_manager__">مدير الوحده التنظيميه</option>
        <option value="مستفيد فعلي">مستفيد فعلي</option>
        <option value="ممثل الوحدة التنظيمية">ممثل الوحدة التنظيمية</option>
        <option value="مدير النظام">مدير النظام</option>
    </select>
    <button type="button" class="rt-clear-btn" id="bnfFilterClear" title="مسح الفلاتر"><i class="bi bi-x-circle"></i> مسح</button>
</div>

<div class="card bnf-tbl">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th style="width:40px;">#</th>
                        <th style="width:44px;"></th>
                        <th>الموظف</th>
                        <th>اسم المستخدم</th>
                        <th>الهوية</th>
                        <th>الجوال</th>
                        <th>البريد</th>
                        <th>الدور</th>
                        <th>الوحدة التنظيمية</th>
                        <th style="width:100px;">التفعيل</th>
                        <th style="width:220px;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody id="bnfBody">
                    <tr><td colspan="11" class="text-center py-4"><div class="spinner-border" style="color:var(--sa-600);"></div></td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="bnfFormModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content bnf-modal">
            <div class="bnf-modal-header">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="bnf-modal-title" id="bnfModalTitle"><i class="bi bi-plus-circle" style="margin-left:8px;"></i>إضافة مستفيد</h5>
                <div class="bnf-modal-subtitle" id="bnfModalSubtitle">أدخل بيانات المستفيد</div>
            </div>
            <div class="bnf-modal-body">
                <input type="hidden" id="bnfId">

                <!-- الدور — أول حقل في النموذج -->
                <div class="bnf-section" id="bnfSectionRole">
                    <div class="bnf-section-title"><i class="bi bi-person-badge-fill"></i>الدور</div>
                    <div class="bnf-form-row">
                        <div class="col-12">
                            <label class="form-label">اختر الدور<span class="required-star">*</span></label>
                            <div class="d-flex flex-column gap-3" role="group" aria-label="الدور">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="bnfSubRole" id="bnfSubRoleActual" value="__actual__" checked>
                                    <label class="form-check-label" for="bnfSubRoleActual">
                                        مستفيد فعلي
                                     
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="bnfSubRole" id="bnfSubRoleAdmin" value="مدير النظام">
                                    <label class="form-check-label" for="bnfSubRoleAdmin">مدير نظام</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- قسم الصورة والهوية -->
                <div class="bnf-section">
                    <div class="bnf-section-title"><i class="bi bi-person-badge"></i>الصورة الشخصية والهوية</div>
                    <div class="bnf-form-row">
                        <div>
                            <label class="form-label">الصورة الشخصية <small class="text-muted">(صورة واحدة)</small></label>
                            <div class="bnf-photo-wrap">
                                <img id="bnfPhotoPreview" class="bnf-photo-preview" src="" alt="" style="display:none;" onerror="this.style.display='none';">
                                <div id="bnfPhotoPlaceholder" class="bnf-photo-preview d-flex align-items-center justify-content-center"><i class="bi bi-person" style="font-size:32px;color:var(--gray-400);"></i></div>
                                <div id="bnfPhotoInputWrap">
                                    <input type="file" class="form-control form-control-sm" id="bnfPhoto" accept="image/*" style="max-width:180px;">
                                </div>
                                <button type="button" class="btn btn-link btn-sm p-0" id="bnfPhotoChangeBtn" style="display:none;font-size:13px;" onclick="bnfShowPhotoFileInput()">تغيير الصورة</button>
                            </div>
                        </div>
                        <div class="bnf-rep-only" id="bnfWrapNationalId">
                            <label class="form-label">الهوية الوطنية<span class="required-star">*</span></label>
                            <input type="text" class="form-control" id="bnfNationalId" maxlength="10" inputmode="numeric" autocomplete="off" placeholder="10 أرقام تبدأ بـ 10 أو 11">
                        </div>
                        <div></div>
                        <div></div>
                    </div>
                </div>

                <!-- قسم التأشير والتوقيع -->
                <div class="bnf-section bnf-rep-only" id="bnfSectionEndorsement">
                    <div class="bnf-section-title"><i class="bi bi-pencil-square"></i>التأشير والتوقيع</div>
                    <div class="bnf-form-row bnf-form-row-2">
                        <div>
                            <label class="form-label">التأشير<span class="required-star">*</span></label>
                            <select class="form-select" id="bnfEndorsementType">
                                <option value="مرفق">مرفق (صورة أو PDF)</option>
                                <option value="التوقيع بالقلم">التوقيع بالقلم</option>
                            </select>
                            <div id="bnfEndorsementFileWrap" class="mt-2">
                                <label class="form-label small">رفع ملف التأشير</label>
                                <input type="file" class="form-control" id="bnfEndorsementFile" accept="image/*,.pdf">
                                <div id="bnfEndorsementPreview" class="bnf-attach-preview-wrap mt-2" style="display:none;"></div>
                            </div>
                            <div id="bnfEndorsementCanvasWrap" class="mt-2" style="display:none;">
                                <label class="form-label small">التوقيع الإلكتروني للتأشير</label>
                                <div class="bnf-sign-canvas-wrap">
                                    <canvas id="bnfEndorsementCanvas" class="bnf-sign-canvas" width="280" height="120"></canvas>
                                    <button type="button" class="btn btn-outline-secondary btn-sm" onclick="bnfClearCanvas('bnfEndorsementCanvas')">مسح</button>
                                </div>
                            </div>
                        </div>
                        <div>
                            <label class="form-label">التوقيع<span class="required-star">*</span></label>
                            <select class="form-select" id="bnfSignatureType">
                                <option value="مرفق">مرفق (صورة أو PDF)</option>
                                <option value="التوقيع بالقلم">التوقيع بالقلم</option>
                            </select>
                            <div id="bnfSignatureFileWrap" class="mt-2">
                                <label class="form-label small">رفع ملف التوقيع</label>
                                <input type="file" class="form-control" id="bnfSignatureFile" accept="image/*,.pdf">
                                <div id="bnfSignaturePreview" class="bnf-attach-preview-wrap mt-2" style="display:none;"></div>
                            </div>
                            <div id="bnfSignatureCanvasWrap" class="mt-2" style="display:none;">
                                <label class="form-label small">التوقيع الإلكتروني</label>
                                <div class="bnf-sign-canvas-wrap">
                                    <canvas id="bnfSignatureCanvas" class="bnf-sign-canvas" width="280" height="120"></canvas>
                                    <button type="button" class="btn btn-outline-secondary btn-sm" onclick="bnfClearCanvas('bnfSignatureCanvas')">مسح</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- قسم الأسماء -->
                <div class="bnf-section">
                    <div class="bnf-section-title"><i class="bi bi-person-lines-fill"></i>الاسم رباعي</div>
                    <div class="bnf-form-row">
                        <div>
                            <label class="form-label">الاسم الأول<span class="required-star">*</span></label>
                            <input type="text" class="form-control" id="bnfFirstName">
                        </div>
                        <div>
                            <label class="form-label">الاسم الثاني<span class="required-star">*</span></label>
                            <input type="text" class="form-control" id="bnfSecondName">
                        </div>
                        <div>
                            <label class="form-label">الاسم الثالث<span class="required-star">*</span></label>
                            <input type="text" class="form-control" id="bnfThirdName">
                        </div>
                        <div>
                            <label class="form-label">الاسم الرابع<span class="required-star">*</span></label>
                            <input type="text" class="form-control" id="bnfFourthName">
                        </div>
                    </div>
                </div>

                <!-- قسم الوحدة والاتصال -->
                <div class="bnf-section bnf-rep-only" id="bnfSectionOuContact">
                    <div class="bnf-section-title"><i class="bi bi-building"></i>الوحدة والاتصال</div>
                    <div class="bnf-form-row">
                        <div>
                            <label class="form-label" for="bnfOuTreeTrigger">الوحدة التنظيمية<span class="required-star">*</span></label>
                            <div class="bnf-ou-tree-wrap">
                                <input type="hidden" id="bnfOrganizationalUnitId" value="">
                                <button type="button" class="form-select bnf-ou-tree-trigger text-end w-100" id="bnfOuTreeTrigger" aria-expanded="false" aria-haspopup="listbox">
                                    <span class="bnf-ou-tree-label text-truncate d-block" id="bnfOuTreeLabel">-- اختر --</span>
                                </button>
                                <div class="bnf-ou-tree-panel d-none" id="bnfOuTreePanel" role="listbox"></div>
                            </div>
                            <div class="mt-3 pt-2 border-top border-light" id="bnfOuRelationWrap">
                                <span class="form-label small text-muted mb-2 d-block"> اختر دور  <span style="font-weight:400;"></span></span>
                                <div class="d-flex flex-wrap gap-3 align-items-center" role="group" aria-label="الصفة في الوحدة">
                                    <div class="form-check mb-0">
                                        <input class="form-check-input" type="radio" name="bnfOuRelation" id="bnfOuRelationMgr" value="manager">
                                        <label class="form-check-label" for="bnfOuRelationMgr">مدير وحدة تنظيمية</label>
                                    </div>
                                    <div class="form-check mb-0">
                                        <input class="form-check-input" type="radio" name="bnfOuRelation" id="bnfOuRelationRep" value="representative">
                                        <label class="form-check-label" for="bnfOuRelationRep">ممثل وحدة تنظيمية</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div>
                            <label class="form-label">الجوال<span class="required-star">*</span></label>
                            <input type="text" class="form-control" id="bnfPhone" maxlength="10" inputmode="numeric" autocomplete="off" placeholder="05xxxxxxxx" title="رقم الجوال ١٠ ارقام تبدا ب ٠٥">
                            <div class="form-text" style="font-size:11px;color:var(--gray-600);">رقم الجوال ١٠ ارقام تبدا ب ٠٥</div>
                        </div>
                        <div>
                            <label class="form-label">البريد الإلكتروني<span class="required-star">*</span></label>
                            <input type="email" class="form-control" id="bnfEmail" placeholder="xxx@@almadinah.gov.sa">
                        </div>
                        <div></div>
                    </div>
                </div>

                <!-- قسم بيانات الدخول -->
                <div class="bnf-section" id="bnfSectionLogin">
                    <div class="bnf-section-title"><i class="bi bi-key-fill"></i>بيانات الدخول</div>
                    <div class="bnf-form-row">
                        <div>
                            <label class="form-label">اسم المستخدم<span class="required-star">*</span></label>
                            <input type="text" class="form-control" id="bnfUsername" placeholder="اسم المستخدم (إنجليزي)" autocomplete="off" dir="ltr" style="text-align:left;">
                        </div>
                        <div></div>
                        <div></div>
                        <div></div>
                    </div>
                    <div class="bnf-form-row bnf-form-row-2" style="margin-top:16px;">
                        <div id="bnfPasswordWrap">
                            <label class="form-label">كلمة المرور<span class="required-star">*</span></label>
                            <input type="password" class="form-control" id="bnfPassword" placeholder="••••••••" autocomplete="new-password">
                            <div class="bnf-pw-hint" role="note" id="bnfPwHintBox">
                                <div class="bnf-pw-hint-title"><i class="bi bi-shield-lock"></i> متطلبات كلمة المرور</div>
                                <div class="bnf-pw-hint-note">تُطبق عند تعيين كلمة مرور جديدة أو تغييرها فقط.</div>
                                <ul class="bnf-pw-hint-list">
                                    <li id="pwReqLen"><span class="bnf-pw-req-icon"><i class="bi bi-circle"></i></span><span><strong>الطول:</strong> 8 أحرف كحد أدنى</span></li>
                                    <li id="pwReqUpper"><span class="bnf-pw-req-icon"><i class="bi bi-circle"></i></span><span><strong>حرف كبير:</strong> مثل A أو B … Z</span></li>
                                    <li id="pwReqLower"><span class="bnf-pw-req-icon"><i class="bi bi-circle"></i></span><span><strong>حرف صغير:</strong> مثل a أو b … z</span></li>
                                    <li id="pwReqDigit"><span class="bnf-pw-req-icon"><i class="bi bi-circle"></i></span><span><strong>رقم:</strong> من 0 إلى 9</span></li>
                                    <li id="pwReqSpecial"><span class="bnf-pw-req-icon"><i class="bi bi-circle"></i></span><span><strong>رمز خاص واحد على الأقل</strong> من: <span class="bnf-pw-hint-chars">!@@#$%^&amp;*</span></span></li>
                                </ul>
                            </div>
                        </div>
                        <div id="bnfConfirmWrap">
                            <label class="form-label">تأكيد كلمة المرور</label>
                            <input type="password" class="form-control" id="bnfConfirmPassword" placeholder="••••••••" autocomplete="new-password">
                        </div>
                    </div>
                </div>

                <div id="bnfError" class="alert alert-danger d-none" style="font-size:14px;"></div>
            </div>
            <div class="bnf-modal-footer">
                <div class="bnf-activation-wrap">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="bnfIsActive" checked>
                        <label class="form-check-label" for="bnfIsActive">التفعيل</label>
                    </div>
                    <span class="text-muted" style="font-size:13px;" id="bnfActivationStatus">مفعل</span>
                </div>
                <div style="display:flex; gap:10px;">
                    <button class="bnf-save-btn" id="bnfSubmitBtn" onclick="bnfSubmit()">حفظ</button>
                    <button class="bnf-cancel-btn" data-bs-dismiss="modal">إلغاء</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Details Modal -->
<div class="modal fade" id="bnfDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content bnf-modal">
            <div class="bnf-modal-header" style="background:var(--info-700);">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="bnf-modal-title"><i class="bi bi-eye" style="margin-left:8px;"></i>تفاصيل المستفيد</h5>
                <div class="bnf-modal-subtitle">عرض جميع البيانات</div>
            </div>
            <div class="bnf-modal-body" id="bnfDetailsBody"></div>
            <div class="bnf-modal-footer" style="justify-content:flex-end;">
                <button class="bnf-cancel-btn" data-bs-dismiss="modal">إغلاق</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="bnfDeleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content bnf-modal">
            <div class="bnf-modal-header" style="background:var(--error-600);">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="bnf-modal-title">حذف المستفيد</h5>
            </div>
            <div class="bnf-modal-body text-center">
                <input type="hidden" id="bnfDeleteId">
                <p style="font-weight:700;font-size:16px;margin-top:8px;color:var(--gray-800);">هل أنت متأكد من حذف هذا المستفيد؟</p>
                <p style="font-size:14px;color:var(--gray-500);" id="bnfDeleteNameLabel"></p>
                <div id="bnfDeleteError" class="alert alert-danger d-none" style="font-size:14px;text-align:right;"></div>
            </div>
            <div class="bnf-modal-footer" style="justify-content:center;">
                <button class="bnf-save-btn" style="background:var(--error-600);" onclick="bnfSubmitDelete()">نعم، حذف</button>
                <button class="bnf-cancel-btn" data-bs-dismiss="modal">إلغاء</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/beneficiaries.js?v=@DateTime.Now.Ticks"></script>
}

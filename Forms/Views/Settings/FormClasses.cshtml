@{
    ViewBag.Title = "أصناف النماذج";
    ViewBag.PageName = "أصناف النماذج";
}

<style>
.fmc-modal { border-radius:20px; border:none; overflow:hidden; box-shadow:0 20px 60px rgba(0,0,0,.15); }
.fmc-modal-header { background:var(--sa-800); padding:24px 28px; position:relative; }
.fmc-modal-header .btn-close-x { position:absolute; top:16px; left:16px; background:none; border:none; color:rgba(255,255,255,.7); font-size:22px; cursor:pointer; padding:4px; line-height:1; transition:color .2s; }
.fmc-modal-header .btn-close-x:hover { color:#fff; }
.fmc-modal-title { color:#fff; font-weight:800; font-size:20px; margin:0; }
.fmc-modal-subtitle { color:rgba(255,255,255,.7); font-size:14px; margin-top:4px; }
.fmc-modal-body { padding:28px; }
.fmc-modal-footer { padding:20px 28px; display:flex; gap:12px; border:none; justify-content:flex-start; }
.fmc-save-btn { padding:12px 32px; border-radius:12px; font-size:15px; font-weight:700; font-family:'Cairo',sans-serif; border:none; cursor:pointer; background:var(--sa-600); color:#fff; transition:all .2s; display:inline-flex; align-items:center; gap:8px; }
.fmc-save-btn:hover { background:var(--sa-700); transform:translateY(-1px); }
.fmc-cancel-btn { padding:12px 32px; border-radius:12px; font-size:15px; font-weight:700; font-family:'Cairo',sans-serif; border:none; cursor:pointer; background:#6b7280; color:#fff; transition:all .2s; }
.fmc-cancel-btn:hover { background:#4b5563; }
.fmc-section-title { font-weight:700; font-size:15px; color:var(--sa-800); margin-bottom:20px; display:flex; align-items:center; gap:8px; padding-bottom:12px; border-bottom:2px solid var(--sa-100); }
.fmc-section-title i { font-size:18px; }
.required-star { color:#ef4444; margin-right:4px; font-weight:700; }
.fmc-action-btn { min-width:80px; border-radius:10px; font-weight:700; padding:7px 14px; font-size:12px; line-height:1.3; display:inline-flex; align-items:center; gap:5px; justify-content:center; cursor:pointer; transition:all .15s; border:2px solid transparent; font-family:'Cairo',sans-serif; white-space:nowrap; }
.fmc-action-btn-detail { border-color:var(--info-500); color:var(--info-500); background:#fff; }
.fmc-action-btn-detail:hover { background:var(--info-50); }
.fmc-action-btn-edit { border-color:var(--sa-600); color:var(--sa-600); background:#fff; }
.fmc-action-btn-edit:hover { background:var(--sa-50); }
.fmc-action-btn-delete { border-color:var(--error-500); color:var(--error-500); background:#fff; }
.fmc-action-btn-delete:hover { background:var(--error-50); }
.fmc-status-pill { display:inline-flex; align-items:center; gap:6px; padding:6px 14px; border-radius:999px; font-weight:700; font-size:12px; }
.fmc-status-pill.active { background:#dcf5e8; color:#0f9f5c; }
.fmc-status-pill.inactive { background:#fde8e8; color:#ef4444; }
.fmc-status-dot { width:8px; height:8px; border-radius:999px; display:inline-block; }
.fmc-status-pill.active .fmc-status-dot { background:#0f9f5c; }
.fmc-status-pill.inactive .fmc-status-dot { background:#ef4444; }
.fmc-color-circle { width:28px; height:28px; border-radius:50%; display:inline-block; border:2px solid rgba(0,0,0,.1); vertical-align:middle; box-shadow:0 1px 4px rgba(0,0,0,.08); }
.table > :not(caption) > * > * { padding-top:0.75rem; padding-bottom:0.75rem; vertical-align:middle; }
.table thead th { background:var(--gray-50) !important; color:var(--gray-700); font-size:13px; font-weight:700; text-align:center; white-space:nowrap; border-bottom:2px solid var(--gray-200); }
.table tbody tr { transition:background .15s; }
.table tbody tr:hover { background:var(--sa-25); }
.table tbody td { border-bottom:1px solid var(--gray-100); }
.fmc-color-picker-wrap { position:relative; display:inline-block; }
.fmc-color-picker-wrap input[type="color"] { width:52px; height:52px; border:2px solid var(--gray-200); border-radius:14px; cursor:pointer; padding:3px; background:#fff; transition:border-color .2s; }
.fmc-color-picker-wrap input[type="color"]:hover { border-color:var(--sa-400); }
.fmc-color-picker-wrap input[type="color"]::-webkit-color-swatch-wrapper { padding:2px; }
.fmc-color-picker-wrap input[type="color"]::-webkit-color-swatch { border-radius:10px; border:none; }
.fmc-color-hex { font-size:13px; color:var(--gray-500); font-weight:600; direction:ltr; text-align:center; font-family:'Courier New',monospace; background:var(--gray-50); padding:4px 10px; border-radius:8px; border:1px solid var(--gray-200); }
.fmc-detail-row { display:flex; align-items:flex-start; gap:12px; padding:14px 0; border-bottom:1px solid var(--gray-100); }
.fmc-detail-row:last-child { border-bottom:none; }
.fmc-detail-label { font-weight:700; font-size:14px; color:var(--gray-600); min-width:120px; }
.fmc-detail-value { font-size:14px; color:var(--gray-900); flex:1; }
.fmc-search-box { position:relative; max-width:320px; }
.fmc-search-box input { padding-right:42px; border-radius:12px; border:2px solid var(--gray-200); font-size:14px; height:44px; }
.fmc-search-box input:focus { border-color:var(--sa-400); box-shadow:0 0 0 3px rgba(37,147,95,.12); }
.fmc-search-box .fmc-search-icon { position:absolute; right:14px; top:50%; transform:translateY(-50%); color:var(--gray-400); font-size:16px; pointer-events:none; }
.fmc-modal-body .form-control,
.fmc-modal-body .form-select { border-radius:10px; border:2px solid var(--gray-200); padding:10px 14px; transition:border-color .2s, box-shadow .2s; }
.fmc-modal-body .form-control:focus { border-color:var(--sa-400); box-shadow:0 0 0 3px rgba(37,147,95,.1); }
.fmc-modal-body .form-label { font-weight:700; font-size:14px; color:var(--gray-700); margin-bottom:8px; }
.fmc-modal-body .form-check-input:checked { background-color:var(--sa-600); border-color:var(--sa-600); }
.fmc-page-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:28px; flex-wrap:wrap; gap:12px; }
.fmc-page-header .fmc-add-btn { border-radius:12px; padding:10px 28px; font-weight:700; font-size:14px; display:inline-flex; align-items:center; gap:8px; }
</style>

<div class="fmc-page-header">
    <div>
        <h2 class="page-title" style="margin:0;">أصناف النماذج</h2>
        <p style="color:var(--gray-500);font-size:14px;margin:6px 0 0;">تصنيف النماذج حسب الأصناف في النظام</p>
    </div>
    <button class="btn btn-primary fmc-add-btn" onclick="fmcShowAddModal()">
        <i class="bi bi-plus-lg"></i>إضافة صنف
    </button>
</div>

<div class="d-flex gap-3 mb-4 flex-wrap align-items-center">
    <div class="fmc-search-box flex-grow-1" style="max-width:400px;">
        <i class="bi bi-search fmc-search-icon"></i>
        <input type="text" class="form-control" id="fmcSearchInput" placeholder="البحث عن صنف بالاسم..." oninput="fmcFilter()">
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th style="width:70px;">الترتيب</th>
                        <th>الصنف</th>
                        <th style="width:130px;">اللون</th>
                        <th>الوصف</th>
                        <th style="width:110px;">التفعيل</th>
                        <th style="width:260px;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody id="fmcBody">
                    <tr><td colspan="6" class="text-center py-4"><div class="spinner-border" style="color:var(--sa-600);"></div></td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="fmcPaginationContainer" class="d-flex justify-content-center mt-4"></div>

<!-- Add Modal -->
<div class="modal fade" id="fmcAddModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content fmc-modal">
            <div class="fmc-modal-header">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="fmc-modal-title"><i class="bi bi-plus-circle" style="margin-left:8px;"></i>إضافة صنف جديد</h5>
                <div class="fmc-modal-subtitle">أدخل بيانات الصنف الجديد</div>
            </div>
            <div class="fmc-modal-body">
                <div class="fmc-section-title"><i class="bi bi-info-circle-fill"></i>معلومات الصنف</div>

                <div class="mb-3">
                    <label class="form-label">اسم الصنف<span class="required-star">*</span></label>
                    <input type="text" class="form-control" id="fmcAddName">
                </div>
                <div class="mb-3">
                    <label class="form-label">الوصف</label>
                    <textarea class="form-control" id="fmcAddDescription" rows="3" placeholder="وصف مختصر لهذا الصنف"></textarea>
                </div>
                <div class="row mb-3">
                    <div class="col-6">
                        <label class="form-label">اللون</label>
                        <div class="d-flex align-items-center gap-3">
                            <div class="fmc-color-picker-wrap">
                                <input type="color" id="fmcAddColor" value="#25935F" oninput="document.getElementById('fmcAddColorHex').textContent=this.value">
                            </div>
                            <div class="fmc-color-hex" id="fmcAddColorHex" style="margin-top:0;">#25935F</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <label class="form-label">التفعيل</label>
                        <div class="d-flex align-items-center gap-3 mt-2">
                            <div class="form-check form-switch m-0">
                                <input class="form-check-input" type="checkbox" id="fmcAddIsActive" checked style="width:48px;height:24px;">
                            </div>
                            <label class="form-check-label" for="fmcAddIsActive" id="fmcAddIsActiveLabel" style="font-weight:600;">مفعل</label>
                        </div>
                    </div>
                </div>

                <div id="fmcAddError" class="alert alert-danger d-none" style="font-size:14px;"></div>
            </div>
            <div class="fmc-modal-footer">
                <button class="fmc-save-btn" onclick="fmcSubmitAdd()">
                    <i class="bi bi-plus-lg"></i>إضافة الصنف
                </button>
                <button class="fmc-cancel-btn" data-bs-dismiss="modal">إلغاء</button>
            </div>
        </div>
    </div>
</div>

<!-- Update Modal -->
<div class="modal fade" id="fmcEditModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content fmc-modal">
            <div class="fmc-modal-header">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="fmc-modal-title"><i class="bi bi-pencil-square" style="margin-left:8px;"></i>تحديث الصنف</h5>
                <div class="fmc-modal-subtitle">تعديل بيانات الصنف</div>
            </div>
            <div class="fmc-modal-body">
                <input type="hidden" id="fmcEditId">
                <div class="fmc-section-title"><i class="bi bi-info-circle-fill"></i>معلومات الصنف</div>

                <div class="mb-3">
                    <label class="form-label">اسم الصنف<span class="required-star">*</span></label>
                    <input type="text" class="form-control" id="fmcEditName">
                </div>
                <div class="mb-3">
                    <label class="form-label">الوصف</label>
                    <textarea class="form-control" id="fmcEditDescription" rows="3"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">الترتيب</label>
                    <input type="number" class="form-control" id="fmcEditSortOrder" min="1">
                </div>
                <div class="row mb-3">
                    <div class="col-6">
                        <label class="form-label">اللون</label>
                        <div class="d-flex align-items-center gap-3">
                            <div class="fmc-color-picker-wrap">
                                <input type="color" id="fmcEditColor" value="#25935F" oninput="document.getElementById('fmcEditColorHex').textContent=this.value">
                            </div>
                            <div class="fmc-color-hex" id="fmcEditColorHex" style="margin-top:0;">#25935F</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <label class="form-label">التفعيل</label>
                        <div class="d-flex align-items-center gap-3 mt-2">
                            <div class="form-check form-switch m-0">
                                <input class="form-check-input" type="checkbox" id="fmcEditIsActive" style="width:48px;height:24px;">
                            </div>
                            <label class="form-check-label" for="fmcEditIsActive" id="fmcEditIsActiveLabel" style="font-weight:600;">مفعل</label>
                        </div>
                    </div>
                </div>

                <div id="fmcEditError" class="alert alert-danger d-none" style="font-size:14px;"></div>
            </div>
            <div class="fmc-modal-footer">
                <button class="fmc-save-btn" onclick="fmcSubmitEdit()">
                    <i class="bi bi-check-lg"></i>حفظ التعديلات
                </button>
                <button class="fmc-cancel-btn" data-bs-dismiss="modal">إلغاء</button>
            </div>
        </div>
    </div>
</div>

<!-- Details Modal -->
<div class="modal fade" id="fmcDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content fmc-modal">
            <div class="fmc-modal-header" style="background:var(--info-700);">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="fmc-modal-title"><i class="bi bi-eye" style="margin-left:8px;"></i>تفاصيل الصنف</h5>
                <div class="fmc-modal-subtitle">عرض بيانات الصنف</div>
            </div>
            <div class="fmc-modal-body" id="fmcDetailsBody">
            </div>
            <div class="fmc-modal-footer" style="justify-content:flex-end;">
                <button class="fmc-cancel-btn" data-bs-dismiss="modal">إغلاق</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="fmcDeleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content fmc-modal">
            <div class="fmc-modal-header" style="background:var(--error-600);">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="fmc-modal-title"><i class="bi bi-trash3" style="margin-left:8px;"></i>حذف الصنف</h5>
            </div>
            <div class="fmc-modal-body text-center">
                <input type="hidden" id="fmcDeleteId">
                <p style="font-weight:700;font-size:16px;margin-top:8px;color:var(--gray-800);">هل أنت متأكد من حذف هذا الصنف؟</p>
                <p style="font-size:14px;color:var(--gray-500);" id="fmcDeleteNameLabel"></p>
                <div id="fmcDeleteError" class="alert alert-danger d-none" style="font-size:14px;text-align:right;"></div>
            </div>
            <div class="fmc-modal-footer" style="justify-content:center;">
                <button class="fmc-save-btn" style="background:var(--error-600);" onclick="fmcSubmitDelete()">
                    نعم، حذف
                </button>
                <button class="fmc-cancel-btn" data-bs-dismiss="modal">إلغاء</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/form-classes.js?v=@DateTime.Now.Ticks"></script>
}

@{
    ViewBag.Title = "سجل العمليات";
    ViewBag.PageName = "سجل العمليات";
}

<style>
.al-page-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:28px; flex-wrap:wrap; gap:12px; }
.al-export-bar { display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
.al-btn-pdf { background:#D92D20; color:#fff; border:none; border-radius:10px; padding:8px 18px; font-weight:700; font-size:13px; font-family:'Cairo',sans-serif; cursor:pointer; display:inline-flex; align-items:center; gap:6px; transition:all .15s; text-decoration:none; }
.al-btn-pdf:hover { background:#b42318; transform:translateY(-1px); color:#fff; }
.al-btn-excel { background:#079455; color:#fff; border:none; border-radius:10px; padding:8px 18px; font-weight:700; font-size:13px; font-family:'Cairo',sans-serif; cursor:pointer; display:inline-flex; align-items:center; gap:6px; transition:all .15s; text-decoration:none; }
.al-btn-excel:hover { background:#067647; transform:translateY(-1px); color:#fff; }
.al-record-count { background:var(--gray-100); color:var(--gray-700); border-radius:10px; padding:6px 16px; font-size:13px; font-weight:700; display:inline-flex; align-items:center; gap:6px; }
.al-badge { display:inline-flex; align-items:center; gap:5px; padding:4px 12px; border-radius:20px; font-size:12px; font-weight:700; white-space:nowrap; }
.al-badge-login { background:#ECFDF3; color:#067647; }
.al-badge-logout { background:#FEF3F2; color:#B42318; }
.al-badge-add { background:#EFF8FF; color:#175CD3; }
.al-badge-activate { background:#ECFDF3; color:#067647; }
.al-badge-deactivate { background:#FFF6ED; color:#B93815; }
.al-badge-role { background:#F4F3FF; color:#5925DC; }
.al-badge-edit { background:#FFF6ED; color:#B93815; }
.al-badge-delete { background:#FEF3F2; color:#B42318; }
.al-badge-default { background:var(--gray-100); color:var(--gray-700); }
.al-ip { direction:ltr; unicode-bidi:embed; font-family:'Consolas','Courier New',monospace; font-size:12px; color:var(--gray-600); }
.table > :not(caption) > * > * { padding-top:0.75rem; padding-bottom:0.75rem; vertical-align:middle; }
.table thead th { background:var(--gray-50) !important; color:var(--gray-700); font-size:13px; font-weight:700; text-align:center; white-space:nowrap; border-bottom:2px solid var(--gray-200); }
.table tbody tr { transition:background .15s; }
.table tbody tr:hover { background:var(--sa-25); }
.table tbody td { border-bottom:1px solid var(--gray-100); text-align:center; font-size:13px; }
.al-empty { text-align:center; padding:40px 20px; color:var(--gray-400); }
.al-empty i { font-size:48px; display:block; margin-bottom:12px; }
.al-pagination { display:flex; justify-content:center; align-items:center; gap:8px; margin-top:20px; flex-wrap:wrap; }
.al-pagination button { border:1px solid var(--gray-300); background:#fff; color:var(--gray-700); border-radius:8px; padding:6px 14px; font-size:13px; font-weight:600; font-family:'Cairo',sans-serif; cursor:pointer; transition:all .15s; }
.al-pagination button:hover { background:var(--sa-50); border-color:var(--sa-400); }
.al-pagination button.active { background:var(--sa-600); color:#fff; border-color:var(--sa-600); }
.al-pagination button:disabled { opacity:.4; cursor:default; }
.al-pagination-info { font-size:13px; color:var(--gray-500); font-weight:600; }
</style>

<!-- Header -->
<div class="al-page-header">
    <div>
        <h2 class="page-title" style="margin:0;">سجل العمليات</h2>
        <p style="color:var(--gray-500);font-size:14px;margin:6px 0 0;">يتم تسجيل وتتبع كافة العمليات والإجراءات المنفذة في النظام</p>
    </div>
    <div class="al-export-bar">
        <a href="/Settings/ExportAuditLogsPdf" target="_blank" class="al-btn-pdf">
            <i class="bi bi-file-earmark-pdf"></i> PDF
        </a>
        <a href="/Settings/ExportAuditLogsExcel" class="al-btn-excel">
            <i class="bi bi-file-earmark-excel"></i> Excel
        </a>
        <span class="al-record-count" id="alRecordCount">
            <i class="bi bi-database"></i> سجل <span id="alCountNum">0</span>
        </span>
    </div>
</div>

<!-- Filters -->
<div class="d-flex gap-3 mb-4 flex-wrap align-items-center">
    <select class="rt-filter-select form-select" id="alFilterUnit" onchange="alOnUnitFilterChange()">
        <option value="">الوحدة التنظيمية</option>
    </select>
    <select class="rt-filter-select form-select" id="alFilterEmployee">
        <option value="">الموظف</option>
    </select>
    <select class="rt-filter-select form-select" id="alFilterAction">
        <option value="">العملية</option>
        <option value="تسجيل دخول">تسجيل دخول</option>
        <option value="تسجيل خروج">تسجيل خروج</option>
        <option value="إضافة مستخدم">إضافة مستخدم</option>
        <option value="تفعيل مستخدم">تفعيل مستخدم</option>
        <option value="تعطيل مستخدم">تعطيل مستخدم</option>
        <option value="تعديل دور مستخدم">تعديل دور مستخدم</option>
        <option value="إضافة مستفيد">إضافة مستفيد</option>
        <option value="تحديث مستفيد">تحديث مستفيد</option>
        <option value="حذف مستفيد">حذف مستفيد</option>
        <option value="إضافة وحدة تنظيمية">إضافة وحدة تنظيمية</option>
        <option value="تحديث وحدة تنظيمية">تحديث وحدة تنظيمية</option>
        <option value="حذف وحدة تنظيمية">حذف وحدة تنظيمية</option>
        <option value="إضافة تصنيف">إضافة تصنيف</option>
        <option value="تحديث تصنيف">تحديث تصنيف</option>
        <option value="حذف تصنيف">حذف تصنيف</option>
    </select>
    <input type="date" class="form-control rt-filter-text" id="alFilterFrom" title="من تاريخ" style="min-width:150px;max-width:170px;">
    <input type="date" class="form-control rt-filter-text" id="alFilterTo" title="إلى تاريخ" style="min-width:150px;max-width:170px;">
    <div class="d-flex gap-2 align-items-center" style="flex-shrink:0;">
        <button type="button" class="btn btn-primary" onclick="alApplyFilters()" style="border-radius:10px;padding:8px 24px;font-weight:700;font-size:13px;">
            <i class="bi bi-funnel"></i> تطبيق
        </button>
        <button type="button" class="rt-clear-btn" onclick="alClearFilters()">
            <i class="bi bi-x-circle"></i> مسح
        </button>
    </div>
</div>

<!-- Table -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th style="width:50px;">#</th>
                        <th style="width:120px;">رقم الهوية</th>
                        <th>اسم المستفيد</th>
                        <th>الوحدة التنظيمية</th>
                        <th style="width:180px;">العملية / الحركة</th>
                        <th style="width:170px;">تاريخ ووقت العملية</th>
                        <th style="width:100px;">المتصفح</th>
                        <th style="width:130px;">عنوان IP</th>
                        <th style="width:120px;">نظام التشغيل</th>
                    </tr>
                </thead>
                <tbody id="alBody">
                    <tr><td colspan="9" class="text-center py-4"><div class="spinner-border" style="color:var(--sa-600);"></div></td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="al-pagination" id="alPagination"></div>

@section Scripts {
<script>
let alAllData = [];
let alFiltered = [];
let alOrgUnits = [];
let alBeneficiaries = [];
let alPage = 1;
const alPerPage = 20;

const badgeMap = {
    'تسجيل دخول': 'al-badge-login',
    'تسجيل خروج': 'al-badge-logout',
    'إضافة مستخدم': 'al-badge-add',
    'إضافة مستفيد': 'al-badge-add',
    'إضافة وحدة تنظيمية': 'al-badge-add',
    'إضافة تصنيف': 'al-badge-add',
    'إضافة صنف نموذج': 'al-badge-add',
    'إضافة نوع نموذج': 'al-badge-add',
    'إضافة حالة نموذج': 'al-badge-add',
    'إضافة جدول جاهز': 'al-badge-add',
    'إضافة قائمة منسدلة': 'al-badge-add',
    'تفعيل مستخدم': 'al-badge-activate',
    'تعطيل مستخدم': 'al-badge-deactivate',
    'تعديل دور مستخدم': 'al-badge-role',
    'تحديث مستفيد': 'al-badge-edit',
    'تحديث وحدة تنظيمية': 'al-badge-edit',
    'تحديث تصنيف': 'al-badge-edit',
    'تحديث صنف نموذج': 'al-badge-edit',
    'تحديث نوع نموذج': 'al-badge-edit',
    'تحديث حالة نموذج': 'al-badge-edit',
    'تحديث جدول جاهز': 'al-badge-edit',
    'تحديث قائمة منسدلة': 'al-badge-edit',
    'حذف مستفيد': 'al-badge-delete',
    'حذف وحدة تنظيمية': 'al-badge-delete',
    'حذف تصنيف': 'al-badge-delete',
    'حذف صنف نموذج': 'al-badge-delete',
    'حذف نوع نموذج': 'al-badge-delete',
    'حذف حالة نموذج': 'al-badge-delete',
    'حذف جدول جاهز': 'al-badge-delete',
    'حذف قائمة منسدلة': 'al-badge-delete',
    'إرسال نموذج': 'al-badge-add',
    'تعبئة نموذج': 'al-badge-edit',
    'اعتماد نموذج': 'al-badge-activate'
};

const iconMap = {
    'تسجيل دخول': 'bi-box-arrow-in-right',
    'تسجيل خروج': 'bi-box-arrow-left',
    'إضافة': 'bi-plus-circle',
    'تفعيل': 'bi-check-circle',
    'تعطيل': 'bi-slash-circle',
    'تعديل': 'bi-pencil-square',
    'تحديث': 'bi-pencil-square',
    'حذف': 'bi-trash',
    'إرسال': 'bi-send',
    'تعبئة': 'bi-pencil',
    'اعتماد': 'bi-check2-circle'
};

function getActionIcon(action) {
    for (const [key, icon] of Object.entries(iconMap)) {
        if (action.startsWith(key)) return icon;
    }
    return 'bi-activity';
}

function getBrowserIcon(browser) {
    const map = { 'Chrome': 'bi-browser-chrome', 'Edge': 'bi-browser-edge', 'Firefox': 'bi-browser-firefox', 'Safari': 'bi-browser-safari' };
    return map[browser] || 'bi-globe';
}

function getOsIcon(os) {
    const map = { 'Windows': 'bi-windows', 'macOS': 'bi-apple', 'Linux': 'bi-ubuntu', 'Android': 'bi-android2', 'iOS': 'bi-phone' };
    return map[os] || 'bi-display';
}

function alRebuildEmployeeSelect(unitId) {
    const empSel = document.getElementById('alFilterEmployee');
    const prev = empSel.value;
    empSel.innerHTML = '<option value="">الموظف</option>';
    let list = alBeneficiaries.slice();
    if (unitId) {
        const uid = parseInt(unitId, 10);
        if (!isNaN(uid)) list = list.filter(b => b.organizationalUnitId === uid);
    }
    list.sort((a, b) => (a.fullName || '').localeCompare(b.fullName || '', 'ar'));
    list.forEach(b => {
        const o = document.createElement('option');
        o.value = b.fullName;
        o.textContent = b.fullName;
        empSel.appendChild(o);
    });
    if (prev && [...empSel.options].some(opt => opt.value === prev)) empSel.value = prev;
    else empSel.value = '';
}

function alOnUnitFilterChange() {
    const unitId = document.getElementById('alFilterUnit').value;
    alRebuildEmployeeSelect(unitId);
}

function alUnitNameFromFilter() {
    const unitId = document.getElementById('alFilterUnit').value;
    if (!unitId) return '';
    const u = alOrgUnits.find(x => String(x.id) === String(unitId));
    return u ? u.name : '';
}

async function alLoad() {
    const r = await apiFetch('/Settings/GetAuditLogs');
    if (!r.success) return;
    alAllData = r.data || [];
    alOrgUnits = r.organizationalUnits || [];
    alBeneficiaries = r.beneficiaries || [];

    const unitSel = document.getElementById('alFilterUnit');
    unitSel.innerHTML = '<option value="">الوحدة التنظيمية</option>';
    alOrgUnits.forEach(u => {
        const o = document.createElement('option');
        o.value = String(u.id);
        o.textContent = u.name;
        unitSel.appendChild(o);
    });

    alRebuildEmployeeSelect('');

    alFiltered = [...alAllData];
    document.getElementById('alCountNum').textContent = alFiltered.length;
    alRender();
}

function alApplyFilters() {
    const unitName = alUnitNameFromFilter();
    const emp = document.getElementById('alFilterEmployee').value;
    const action = document.getElementById('alFilterAction').value;
    const from = document.getElementById('alFilterFrom').value;
    const to = document.getElementById('alFilterTo').value;

    alFiltered = alAllData.filter(d => {
        if (unitName && d.organizationalUnit !== unitName) return false;
        if (emp && d.userName !== emp) return false;
        if (action && d.action !== action) return false;
        if (from) {
            const logDate = d.createdAt.substring(0, 10);
            if (logDate < from) return false;
        }
        if (to) {
            const logDate = d.createdAt.substring(0, 10);
            if (logDate > to) return false;
        }
        return true;
    });

    document.getElementById('alCountNum').textContent = alFiltered.length;
    alPage = 1;
    alRender();
}

function alClearFilters() {
    document.getElementById('alFilterUnit').value = '';
    document.getElementById('alFilterAction').value = '';
    document.getElementById('alFilterFrom').value = '';
    document.getElementById('alFilterTo').value = '';
    alRebuildEmployeeSelect('');
    alFiltered = [...alAllData];
    document.getElementById('alCountNum').textContent = alFiltered.length;
    alPage = 1;
    alRender();
}

function alRender() {
    const body = document.getElementById('alBody');
    const start = (alPage - 1) * alPerPage;
    const pageData = alFiltered.slice(start, start + alPerPage);

    if (alFiltered.length === 0) {
        body.innerHTML = `<tr><td colspan="9" class="al-empty"><i class="bi bi-inbox"></i><div>لا توجد سجلات</div></td></tr>`;
        document.getElementById('alPagination').innerHTML = '';
        return;
    }

    body.innerHTML = pageData.map((d, i) => {
        const num = start + i + 1;
        const badgeCls = badgeMap[d.action] || 'al-badge-default';
        const actionIcon = getActionIcon(d.action);
        const browserIcon = getBrowserIcon(d.browser);
        const osIcon = getOsIcon(d.operatingSystem);

        return `<tr>
            <td style="font-weight:700;color:var(--gray-500);">${num}</td>
            <td style="font-family:'Consolas',monospace;font-size:12px;">${esc(d.nationalId || '—')}</td>
            <td style="font-weight:600;text-align:right;">${esc(d.userName || '—')}</td>
            <td style="text-align:right;">${esc(d.organizationalUnit || '—')}</td>
            <td><span class="al-badge ${badgeCls}"><i class="bi ${actionIcon}"></i> ${esc(d.action)}</span></td>
            <td style="font-size:12px;color:var(--gray-600);direction:ltr;">${esc(d.createdAt)}</td>
            <td><i class="bi ${browserIcon}" style="margin-left:4px;color:var(--gray-500);"></i>${esc(d.browser || '—')}</td>
            <td><span class="al-ip">${esc(d.ipAddress || '—')}</span></td>
            <td><i class="bi ${osIcon}" style="margin-left:4px;color:var(--gray-500);"></i>${esc(d.operatingSystem || '—')}</td>
        </tr>`;
    }).join('');

    alRenderPagination();
}

function alRenderPagination() {
    const total = Math.ceil(alFiltered.length / alPerPage);
    if (total <= 1) { document.getElementById('alPagination').innerHTML = ''; return; }

    let html = `<span class="al-pagination-info">صفحة ${alPage} من ${total}</span>`;
    html += `<button onclick="alGoPage(${alPage - 1})" ${alPage <= 1 ? 'disabled' : ''}><i class="bi bi-chevron-right"></i></button>`;

    const maxVisible = 7;
    let startP = Math.max(1, alPage - Math.floor(maxVisible / 2));
    let endP = Math.min(total, startP + maxVisible - 1);
    if (endP - startP + 1 < maxVisible) startP = Math.max(1, endP - maxVisible + 1);

    if (startP > 1) {
        html += `<button onclick="alGoPage(1)">1</button>`;
        if (startP > 2) html += `<button disabled>…</button>`;
    }
    for (let p = startP; p <= endP; p++) {
        html += `<button onclick="alGoPage(${p})" class="${p === alPage ? 'active' : ''}">${p}</button>`;
    }
    if (endP < total) {
        if (endP < total - 1) html += `<button disabled>…</button>`;
        html += `<button onclick="alGoPage(${total})">${total}</button>`;
    }

    html += `<button onclick="alGoPage(${alPage + 1})" ${alPage >= total ? 'disabled' : ''}><i class="bi bi-chevron-left"></i></button>`;
    document.getElementById('alPagination').innerHTML = html;
}

function alGoPage(p) {
    const total = Math.ceil(alFiltered.length / alPerPage);
    if (p < 1 || p > total) return;
    alPage = p;
    alRender();
    document.querySelector('.table')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function esc(s) {
    if (!s) return '';
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
}

alLoad();
</script>
}

@{
    ViewBag.Title = "الوحدات التنظيمية";
    ViewBag.PageName = "الوحدات التنظيمية";
}

<style>
.bnf-modal { border-radius:16px; border:none; overflow:hidden; box-shadow:0 8px 50px rgba(0,0,0,.2); }
.bnf-modal-header { background:var(--sa-700); padding:18px 24px; position:relative; }
.bnf-modal-header .btn-close-x { position:absolute; top:14px; left:14px; background:none; border:none; color:rgba(255,255,255,.7); font-size:18px; cursor:pointer; }
.bnf-modal-header .btn-close-x:hover { color:#fff; }
.bnf-modal-title { color:#fff; font-weight:700; font-size:16px; margin:0; }
.bnf-modal-subtitle { color:rgba(255,255,255,.7); font-size:12px; margin-top:2px; }
.bnf-modal-body { padding:24px; max-height:75vh; overflow-y:auto; }
.bnf-modal-footer { padding:16px 24px; display:flex; flex-wrap:wrap; gap:10px; border:none; justify-content:flex-end; align-items:center; background:var(--gray-50); border-top:1px solid var(--gray-100); }
.bnf-save-btn { padding:9px 24px; border-radius:10px; font-size:13px; font-weight:700; font-family:'Cairo',sans-serif; border:none; cursor:pointer; background:var(--sa-600); color:#fff; transition:all .15s; }
.bnf-save-btn:hover { background:var(--sa-700); }
.bnf-cancel-btn { padding:9px 24px; border-radius:10px; font-size:13px; font-weight:700; font-family:'Cairo',sans-serif; border:none; cursor:pointer; background:#6b7280; color:#fff; transition:all .15s; }
.bnf-cancel-btn:hover { background:#4b5563; }
.bnf-page-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:28px; flex-wrap:wrap; gap:12px; width:100%; max-width:100%; box-sizing:border-box; }
.bnf-settings-page { width:100%; max-width:100%; box-sizing:border-box; }
.bnf-tbl { width:100%; max-width:100%; min-width:0; box-sizing:border-box; }
.bnf-tbl .table-responsive { overflow-x:auto; -webkit-overflow-scrolling:touch; max-width:100%; }
.bnf-tbl .table { width:100%; margin-bottom:0; min-width:1180px; font-size:13px; }
.bnf-tbl .table > :not(caption) > * > * { padding-top:0.72rem; padding-bottom:0.72rem; vertical-align:middle; }
.bnf-tbl .table thead th { background:var(--gray-50) !important; color:var(--gray-700); font-size:13px; font-weight:700; text-align:center; white-space:nowrap; border-bottom:2px solid var(--gray-200); padding-left:10px; padding-right:10px; }
.bnf-tbl .table tbody tr { transition:background .15s; }
.bnf-tbl .table tbody tr:hover { background:var(--sa-25); }
.bnf-tbl .table tbody td { border-bottom:1px solid var(--gray-100); padding-left:10px; padding-right:10px; }
.ou-action-btn { padding:8px 14px; border-radius:10px; font-weight:700; font-size:12px; border:none; cursor:pointer; font-family:'Cairo',sans-serif; display:inline-flex; align-items:center; gap:6px; white-space:nowrap; }
.ou-action-btn-detail { background:var(--gray-100); color:var(--gray-700); }
.ou-action-btn-detail:hover { background:var(--gray-200); color:var(--gray-800); }
.ou-action-btn-edit { background:#198754; color:#fff; }
.ou-action-btn-edit:hover { background:#157347; color:#fff; }
.ou-action-btn-delete { background:#dc3545; color:#fff; }
.ou-action-btn-delete:hover { background:#bb2d3b; color:#fff; }
.ou-status { display:inline-flex; align-items:center; padding:4px 10px; border-radius:999px; font-weight:700; font-size:11px; }
.ou-on { background:#dcf5e8; color:#0f9f5c; }
.ou-off { background:#fde8e8; color:#ef4444; }
.required-star { color:#ef4444; margin-right:4px; }
</style>

<div class="bnf-settings-page">
    <div class="bnf-page-header">
        <div>
            <h2 class="page-title" style="margin:0;">الوحدات التنظيمية</h2>
            <p style="color:var(--gray-500);font-size:14px;margin:6px 0 0;">إضافة وتعديل الوحدات؛ تحديد الرئيسية أو الفرعية من خلال «الوحدة التنظيمية الرئيسية» فقط.</p>
        </div>
        <button type="button" class="btn btn-primary" onclick="ouShowAddModal()" style="border-radius:12px;padding:10px 28px;font-weight:700;font-size:14px;display:inline-flex;align-items:center;gap:8px;">
            <i class="bi bi-plus-lg"></i> إضافة وحدة
        </button>
    </div>

    <div class="d-flex gap-3 mb-4 flex-wrap align-items-center rt-filters">
        <div class="rt-search-box" style="min-width:200px;max-width:280px;">
            <i class="bi bi-search rt-search-icon"></i>
            <input type="text" class="form-control" id="ouSearch" placeholder="بحث بالاسم..." autocomplete="off">
        </div>
        <select class="form-select rt-filter-select" id="ouFilterClassification" style="min-width:200px;">
            <option value="">كل التصنيفات</option>
        </select>
    </div>

    <div class="card bnf-tbl">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th style="width:40px;">#</th>
                            <th>اسم الوحدة</th>
                            <th>التصنيف</th>
                            <th>الوحدة الرئيسية</th>
                            <th style="width:88px;text-align:center;">عدد المنسوبين</th>
                            <th>مدير الوحدة التنظيمية</th>
                            <th style="width:90px;">الترتيب</th>
                            <th style="width:100px;">التفعيل</th>
                            <th style="min-width:280px;">الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody id="ouBody">
                        <tr><td colspan="9" class="text-center py-4"><div class="spinner-border" style="color:var(--sa-600);"></div></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="ouModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content bnf-modal">
            <div class="bnf-modal-header">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="bnf-modal-title" id="ouModalTitle"><i class="bi bi-diagram-3" style="margin-left:8px;"></i>إضافة وحدة تنظيمية</h5>
                <div class="bnf-modal-subtitle">اختر الوحدة الرئيسية من قائمة تعرض الهيكل شجرياً حسب التبعية.</div>
            </div>
            <div class="bnf-modal-body">
                <div class="mb-3">
                    <label class="form-label">اسم الوحدة<span class="required-star">*</span></label>
                    <input type="text" class="form-control" id="ouName" maxlength="200" autocomplete="off">
                </div>
                <div class="mb-3">
                    <label class="form-label">التصنيف التنظيمي<span class="required-star">*</span></label>
                    <select class="form-select" id="ouClassificationId"></select>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="ouParentId">الوحدة التنظيمية الرئيسية</label>
                    <select class="form-select" id="ouParentId" style="font-family:'Cairo',sans-serif;"></select>
                    <p class="text-muted small mb-0 mt-2" style="font-size:11px;">المسافة والرمز └ تمثل مستوى التبعية في الشجرة؛ اترك «وحدة رئيسية» لإنشاء وحدة في الجذر.</p>
                </div>
                <div class="mb-3" id="ouSortWrap" style="display:none;">
                    <label class="form-label">ترتيب العرض<span class="required-star">*</span></label>
                    <input type="number" class="form-control" id="ouSortOrder" min="1" step="1">
                </div>
                <div class="form-check form-switch mb-2">
                    <input class="form-check-input" type="checkbox" id="ouIsActive" checked>
                    <label class="form-check-label" for="ouIsActive">الوحدة مفعّلة</label>
                </div>
                <div id="ouError" class="alert alert-danger d-none" style="font-size:14px;"></div>
            </div>
            <div class="bnf-modal-footer">
                <button type="button" class="bnf-save-btn" onclick="ouSave()">حفظ</button>
                <button type="button" class="bnf-cancel-btn" data-bs-dismiss="modal">إلغاء</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="ouDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content bnf-modal">
            <div class="bnf-modal-header" style="background:var(--info-700);">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="bnf-modal-title"><i class="bi bi-info-circle" style="margin-left:8px;"></i>تفاصيل الوحدة التنظيمية</h5>
                <div class="bnf-modal-subtitle" id="ouDetailsSubtitle"></div>
            </div>
            <div class="bnf-modal-body" id="ouDetailsBody"></div>
            <div class="bnf-modal-footer" style="justify-content:flex-end;">
                <button type="button" class="bnf-cancel-btn" data-bs-dismiss="modal">إغلاق</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="ouDeleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content bnf-modal">
            <div class="bnf-modal-header" style="background:var(--error-600);">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="bnf-modal-title">حذف وحدة تنظيمية</h5>
            </div>
            <div class="bnf-modal-body text-center">
                <p style="font-weight:700;font-size:16px;margin-top:8px;color:var(--gray-800);">هل أنت متأكد من الحذف؟</p>
                <p style="font-size:14px;color:var(--gray-500);" id="ouDeleteName"></p>
                <div id="ouDeleteErr" class="alert alert-danger d-none" style="font-size:14px;text-align:right;"></div>
            </div>
            <div class="bnf-modal-footer" style="justify-content:center;">
                <button type="button" class="bnf-save-btn" style="background:var(--error-600);" onclick="ouSubmitDelete()">نعم، حذف</button>
                <button type="button" class="bnf-cancel-btn" data-bs-dismiss="modal">إلغاء</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/organizational-units.js?v=@DateTime.Now.Ticks"></script>
}

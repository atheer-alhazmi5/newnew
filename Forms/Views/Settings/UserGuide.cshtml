@{
    ViewBag.Title = "دليل المستخدم";
    ViewBag.PageName = "دليل المستخدم";
}

<style>
.ug-modal { border-radius:20px; border:none; overflow:hidden; box-shadow:0 20px 60px rgba(0,0,0,.15); }
.ug-modal-header { background:var(--sa-800); padding:24px 28px; position:relative; }
.ug-modal-header .btn-close-x { position:absolute; top:16px; left:16px; background:none; border:none; color:rgba(255,255,255,.7); font-size:22px; cursor:pointer; padding:4px; line-height:1; transition:color .2s; }
.ug-modal-header .btn-close-x:hover { color:#fff; }
.ug-modal-title { color:#fff; font-weight:800; font-size:20px; margin:0; }
.ug-modal-subtitle { color:rgba(255,255,255,.7); font-size:14px; margin-top:4px; }
.ug-modal-body { padding:28px; max-height:75vh; overflow-y:auto; }
.ug-modal-footer { padding:20px 28px; display:flex; gap:12px; border:none; justify-content:flex-start; background:var(--gray-50); }
.ug-save-btn { padding:12px 32px; border-radius:12px; font-size:15px; font-weight:700; font-family:'Cairo',sans-serif; border:none; cursor:pointer; background:var(--sa-600); color:#fff; transition:all .2s; display:inline-flex; align-items:center; gap:8px; }
.ug-save-btn:hover { background:var(--sa-700); transform:translateY(-1px); }
.ug-cancel-btn { padding:12px 32px; border-radius:12px; font-size:15px; font-weight:700; font-family:'Cairo',sans-serif; border:none; cursor:pointer; background:#6b7280; color:#fff; transition:all .2s; }
.ug-cancel-btn:hover { background:#4b5563; }
.ug-section-title { font-weight:700; font-size:15px; color:var(--sa-800); margin-bottom:18px; display:flex; align-items:center; gap:8px; padding-bottom:12px; border-bottom:2px solid var(--sa-100); }
.ug-section-title i { font-size:18px; }
.required-star { color:#ef4444; margin-right:4px; font-weight:700; }
.ug-action-btn { min-width:80px; border-radius:10px; font-weight:700; padding:7px 14px; font-size:12px; line-height:1.3; display:inline-flex; align-items:center; gap:5px; justify-content:center; cursor:pointer; transition:all .15s; border:2px solid transparent; font-family:'Cairo',sans-serif; white-space:nowrap; }
.ug-action-btn-detail { border-color:var(--info-500); color:var(--info-500); background:#fff; }
.ug-action-btn-detail:hover { background:var(--info-50); }
.ug-action-btn-edit { border-color:var(--sa-600); color:var(--sa-600); background:#fff; }
.ug-action-btn-edit:hover { background:var(--sa-50); }
.ug-action-btn-delete { border-color:var(--error-500); color:var(--error-500); background:#fff; }
.ug-action-btn-delete:hover { background:var(--error-50); }
.ug-status-pill { display:inline-flex; align-items:center; gap:6px; padding:6px 14px; border-radius:999px; font-weight:700; font-size:12px; }
.ug-status-pill.active { background:#dcf5e8; color:#0f9f5c; }
.ug-status-pill.inactive { background:#fde8e8; color:#ef4444; }
.ug-status-dot { width:8px; height:8px; border-radius:999px; display:inline-block; }
.ug-status-pill.active .ug-status-dot { background:#0f9f5c; }
.ug-status-pill.inactive .ug-status-dot { background:#ef4444; }
.ug-color-circle { width:28px; height:28px; border-radius:50%; display:inline-block; border:2px solid rgba(0,0,0,.1); vertical-align:middle; box-shadow:0 1px 4px rgba(0,0,0,.08); }
.table > :not(caption) > * > * { padding-top:0.75rem; padding-bottom:0.75rem; vertical-align:middle; }
.table thead th { background:var(--gray-50) !important; color:var(--gray-700); font-size:13px; font-weight:700; text-align:center; white-space:nowrap; border-bottom:2px solid var(--gray-200); }
.table tbody tr { transition:background .15s; }
.table tbody tr:hover { background:var(--sa-25); }
.table tbody td { border-bottom:1px solid var(--gray-100); }
.ug-color-picker-wrap { position:relative; display:inline-block; }
.ug-color-picker-wrap input[type="color"] { width:52px; height:52px; border:2px solid var(--gray-200); border-radius:14px; cursor:pointer; padding:3px; background:#fff; transition:border-color .2s; }
.ug-color-picker-wrap input[type="color"]:hover { border-color:var(--sa-400); }
.ug-color-picker-wrap input[type="color"]::-webkit-color-swatch-wrapper { padding:2px; }
.ug-color-picker-wrap input[type="color"]::-webkit-color-swatch { border-radius:10px; border:none; }
.ug-color-hex { font-size:13px; color:var(--gray-500); font-weight:600; direction:ltr; text-align:center; font-family:'Courier New',monospace; background:var(--gray-50); padding:4px 10px; border-radius:8px; border:1px solid var(--gray-200); }
.ug-search-box { position:relative; max-width:320px; }
.ug-search-box input { padding-right:42px; border-radius:12px; border:2px solid var(--gray-200); font-size:14px; height:44px; }
.ug-search-box input:focus { border-color:var(--sa-400); box-shadow:0 0 0 3px rgba(37,147,95,.12); }
.ug-search-box .ug-search-icon { position:absolute; right:14px; top:50%; transform:translateY(-50%); color:var(--gray-400); font-size:16px; pointer-events:none; }
.ug-modal-body .form-control,
.ug-modal-body .form-select { border-radius:10px; border:2px solid var(--gray-200); padding:10px 14px; transition:border-color .2s, box-shadow .2s; }
.ug-modal-body .form-control:focus,
.ug-modal-body .form-select:focus { border-color:var(--sa-400); box-shadow:0 0 0 3px rgba(37,147,95,.1); }
.ug-modal-body .form-label { font-weight:700; font-size:14px; color:var(--gray-700); margin-bottom:8px; }
.ug-modal-body .form-check-input:checked { background-color:var(--sa-600); border-color:var(--sa-600); }
.ug-page-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:28px; flex-wrap:wrap; gap:12px; }
.ug-page-header .ug-add-btn { border-radius:12px; padding:10px 28px; font-weight:700; font-size:14px; display:inline-flex; align-items:center; gap:8px; }
.ug-icon-picker { display:flex; flex-wrap:wrap; gap:8px; margin-top:8px; max-height:160px; overflow-y:auto; padding:6px; border:1px solid var(--gray-200); border-radius:10px; background:var(--gray-50); }
.ug-icon-picker-item { width:44px; height:44px; border-radius:10px; border:2px solid var(--gray-200); display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:20px; color:var(--gray-600); transition:all .2s; background:#fff; }
.ug-icon-picker-item:hover { border-color:var(--sa-400); background:var(--sa-50); color:var(--sa-700); }
.ug-icon-picker-item.selected { border-color:var(--sa-600); background:var(--sa-100); color:var(--sa-700); box-shadow:0 0 0 3px rgba(37,147,95,.15); }
.ug-icon-display { width:34px; height:34px; border-radius:8px; background:var(--sa-50); color:var(--sa-700); display:inline-flex; align-items:center; justify-content:center; font-size:16px; overflow:hidden; }
.ug-icon-display img { width:100%; height:100%; object-fit:cover; border-radius:8px; }
.ug-table-card { border-radius:16px; border:none; box-shadow:0 2px 12px rgba(0,0,0,.06); overflow:hidden; }
.ug-order-pill { display:inline-block; padding:4px 12px; border-radius:999px; background:var(--gray-100); color:var(--gray-700); font-weight:700; font-size:12.5px; direction:ltr; min-width:42px; text-align:center; }
.ug-order-pill.is-root { background:var(--sa-100); color:var(--sa-800); }
.ug-row-name { display:inline-flex; align-items:center; gap:8px; }
.ug-row-name .child-indent { color:var(--gray-300); font-size:14px; }
.ug-row-name .branch-tag { display:inline-block; font-size:10.5px; font-weight:700; color:var(--info-700); background:var(--info-50); border:1px solid var(--info-100); padding:1px 8px; border-radius:999px; margin-inline-start:6px; }
.ug-parent-cell { font-size:12.5px; color:var(--gray-700); }
.ug-parent-cell .root-tag { display:inline-flex; align-items:center; gap:4px; color:var(--sa-700); font-weight:700; }
.ug-parent-cell .muted { color:var(--gray-400); }
.ug-attach-preview { width:80px; height:80px; border-radius:10px; border:2px dashed var(--gray-300); background:var(--gray-50); display:inline-flex; align-items:center; justify-content:center; color:var(--gray-400); overflow:hidden; }
.ug-attach-preview img { width:100%; height:100%; object-fit:cover; }
.ug-attach-row { display:flex; align-items:center; gap:14px; flex-wrap:wrap; }
.ug-attach-row .btn-attach { padding:8px 16px; border-radius:10px; font-weight:700; font-size:13px; background:var(--sa-50); color:var(--sa-700); border:2px solid var(--sa-200); cursor:pointer; display:inline-flex; align-items:center; gap:6px; font-family:'Cairo',sans-serif; }
.ug-attach-row .btn-attach:hover { background:var(--sa-100); border-color:var(--sa-300); }
.ug-attach-row .btn-attach-clear { padding:6px 12px; border-radius:8px; background:#fff; color:var(--error-600); border:2px solid var(--error-200); font-weight:700; font-size:12px; cursor:pointer; }
.ug-attach-row input[type="file"] { display:none; }
.ug-content-pre { white-space:pre-wrap; line-height:1.8; padding:12px 14px; background:var(--gray-50); border:1px solid var(--gray-200); border-radius:10px; font-size:13px; color:var(--gray-800); max-height:240px; overflow-y:auto; }
.ug-rich-editor { border:2px solid var(--gray-200); border-radius:10px; background:#fff; }
.ug-rich-editor .ql-toolbar { border:none; border-bottom:2px solid var(--gray-100); border-radius:10px 10px 0 0; font-family:'Cairo',sans-serif; }
.ug-rich-editor .ql-container { border:none; font-family:'Cairo',sans-serif; font-size:14px; min-height:180px; border-radius:0 0 10px 10px; }
.ug-rich-editor .ql-editor { min-height:160px; direction:rtl; text-align:right; }
.ug-rich-content { line-height:1.85; font-size:14px; color:var(--gray-800); padding:12px 14px; background:var(--gray-50); border:1px solid var(--gray-200); border-radius:10px; max-height:320px; overflow-y:auto; direction:rtl; text-align:right; }
.ug-rich-content img { max-width:100%; height:auto; border-radius:8px; }
.ug-clear-filter-btn { padding:8px 16px; border-radius:10px; font-weight:700; font-size:13px; background:var(--gray-100); color:var(--gray-700); border:2px solid var(--gray-200); cursor:pointer; }
.ug-clear-filter-btn:hover { background:var(--gray-200); }
</style>

@section Styles {
<link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet">
}

<div class="ug-page-header">
    <div>
        <h2 class="page-title" style="margin:0;">دليل المستخدم</h2>
        <p style="color:var(--gray-500);font-size:14px;margin:6px 0 0;">إدارة محتويات دليل المستخدم في النظام</p>
    </div>
    <button class="btn btn-primary ug-add-btn" onclick="ugShowAddModal()">
        <i class="bi bi-plus-lg"></i>إنشاء قائمة / صفحة
    </button>
</div>

<div class="d-flex gap-3 mb-4 flex-wrap align-items-center rt-filters">
    <div class="ug-search-box flex-grow-1" style="max-width:400px;">
        <i class="bi bi-search ug-search-icon"></i>
        <input type="text" class="form-control" id="ugSearchInput" placeholder="بحث بالاسم ..." oninput="ugApplyFilter()">
    </div>
    <select class="rt-filter-select form-select" id="ugActiveFilter" onchange="ugApplyFilter()" style="max-width:180px;height:44px;">
        <option value="">التفعيل — الكل</option>
        <option value="1">مفعل</option>
        <option value="0">معطل</option>
    </select>
    <button type="button" class="ug-clear-filter-btn" onclick="ugClearFilters()"><i class="bi bi-x-circle"></i> مسح</button>
</div>

<div class="card ug-table-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th style="width:90px;">الترتيب</th>
                        <th style="width:90px;">الأيقونة</th>
                        <th style="text-align:right;">اسم القائمة / الصفحة</th>
                        <th style="text-align:right;">القائمة الرئيسية (الجذر)</th>
                        <th style="width:110px;">اللون</th>
                        <th style="width:110px;">التفعيل</th>
                        <th style="width:260px;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody id="ugBody">
                    <tr><td colspan="7" class="text-center py-4"><div class="spinner-border" style="color:var(--sa-600);"></div></td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="ugPaginationContainer" class="d-flex justify-content-center mt-4"></div>

<div class="modal fade" id="ugAddModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content ug-modal">
            <div class="ug-modal-header">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="ug-modal-title"><i class="bi bi-plus-circle" style="margin-left:8px;"></i>إنشاء قائمة / صفحة</h5>
                <div class="ug-modal-subtitle">أضف عنصراً جديداً لدليل المستخدم</div>
            </div>
            <div class="ug-modal-body">
                <div class="ug-section-title"><i class="bi bi-info-circle-fill"></i>المعلومات الأساسية</div>

                <div class="mb-3">
                    <label class="form-label">اسم القائمة / الصفحة<span class="required-star">*</span></label>
                    <input type="text" class="form-control" id="ugAddName" placeholder="مثال: دليل هيكل الوحدة التنظيمية">
                </div>

                <div class="mb-3">
                    <label class="form-label" for="ugAddParent">القائمة الرئيسية</label>
                    <select class="form-select" id="ugAddParent" style="font-family:'Cairo',sans-serif;">
                        <option value="">— رئيسية (بدون أب في الشجرة) —</option>
                    </select>
                    <small class="text-muted" style="display:block;margin-top:6px;font-size:12px;">المسافة والرمز └ تمثل مستوى التبعية في الشجرة؛ اترك «رئيسية» لإنشاء عنصر في الجذر.</small>
                </div>

                <div class="mb-3">
                    <label class="form-label">الأيقونة</label>
                    <div class="ug-attach-row">
                        <div class="ug-attach-preview ug-icon-preview" id="ugAddIconPreview">
                            <i class="bi bi-image" style="font-size:28px;"></i>
                        </div>
                        <label class="btn-attach" for="ugAddIconInput"><i class="bi bi-paperclip"></i> مرفق</label>
                        <button type="button" class="btn-attach-clear d-none" id="ugAddIconClear" onclick="ugClearIcon('Add')"><i class="bi bi-x-lg"></i> إزالة</button>
                        <input type="file" id="ugAddIconInput" accept="image/*">
                        <input type="hidden" id="ugAddIcon" value="">
                    </div>

                </div>

                <div class="mb-3">
                    <label class="form-label">المحتوى<span class="required-star">*</span></label>
                    <div id="ugAddContentEditor" class="ug-rich-editor"></div>
                    <input type="hidden" id="ugAddContent" value="">
                </div>

                <div class="mb-3">
                    <label class="form-label">المرفقات</label>
                    <div class="ug-attach-row">
                        <div class="ug-attach-preview" id="ugAddAttachPreview">
                            <i class="bi bi-image" style="font-size:28px;"></i>
                        </div>
                        <label class="btn-attach" for="ugAddAttachInput"><i class="bi bi-paperclip"></i> إرفاق صورة</label>
                        <button type="button" class="btn-attach-clear d-none" id="ugAddAttachClear" onclick="ugClearAttach('Add')"><i class="bi bi-x-lg"></i> إزالة</button>
                        <input type="file" id="ugAddAttachInput" accept="image/*">
                        <input type="hidden" id="ugAddAttachData" value="">
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-6">
                        <label class="form-label">اللون</label>
                        <div class="d-flex align-items-center gap-3">
                            <div class="ug-color-picker-wrap">
                                <input type="color" id="ugAddColor" value="#25935F" oninput="document.getElementById('ugAddColorHex').textContent=this.value">
                            </div>
                            <div class="ug-color-hex" id="ugAddColorHex">#25935F</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <label class="form-label">التفعيل</label>
                        <div class="d-flex align-items-center gap-3 mt-2">
                            <div class="form-check form-switch m-0">
                                <input class="form-check-input" type="checkbox" id="ugAddIsActive" checked style="width:48px;height:24px;">
                            </div>
                            <label class="form-check-label" for="ugAddIsActive" id="ugAddIsActiveLabel" style="font-weight:600;">مفعل</label>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">الملاحظات</label>
                    <textarea class="form-control" id="ugAddNotes" rows="2" placeholder="ملاحظات اختيارية"></textarea>
                </div>

                <div id="ugAddError" class="alert alert-danger d-none" style="font-size:14px;"></div>
            </div>
            <div class="ug-modal-footer">
                <button class="ug-save-btn" onclick="ugSubmitAdd()">
                    <i class="bi bi-plus-lg"></i>إضافة
                </button>
                <button class="ug-cancel-btn" data-bs-dismiss="modal">إلغاء</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit  -->
<div class="modal fade" id="ugEditModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content ug-modal">
            <div class="ug-modal-header">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="ug-modal-title"><i class="bi bi-pencil-square" style="margin-left:8px;"></i>تحديث القائمة / الصفحة</h5>
                <div class="ug-modal-subtitle">تعديل بيانات العنصر</div>
            </div>
            <div class="ug-modal-body">
                <input type="hidden" id="ugEditId">
                <div class="ug-section-title"><i class="bi bi-info-circle-fill"></i>المعلومات الأساسية</div>

                <div class="mb-3">
                    <label class="form-label">اسم القائمة / الصفحة<span class="required-star">*</span></label>
                    <input type="text" class="form-control" id="ugEditName">
                </div>

                <div class="mb-3">
                    <label class="form-label" for="ugEditParent">القائمة الرئيسية</label>
                    <select class="form-select" id="ugEditParent" style="font-family:'Cairo',sans-serif;">
                        <option value="">— رئيسية (بدون أب في الشجرة) —</option>
                    </select>
                    <small class="text-muted" style="display:block;margin-top:6px;font-size:12px;">المسافة والرمز └ تمثل مستوى التبعية في الشجرة.</small>
                </div>

                <div class="mb-3">
                    <label class="form-label">الأيقونة</label>
                    <div class="ug-attach-row">
                        <div class="ug-attach-preview ug-icon-preview" id="ugEditIconPreview">
                            <i class="bi bi-image" style="font-size:28px;"></i>
                        </div>
                        <label class="btn-attach" for="ugEditIconInput"><i class="bi bi-paperclip"></i> مرفق</label>
                        <button type="button" class="btn-attach-clear d-none" id="ugEditIconClear" onclick="ugClearIcon('Edit')"><i class="bi bi-x-lg"></i> إزالة</button>
                        <input type="file" id="ugEditIconInput" accept="image/*">
                        <input type="hidden" id="ugEditIcon" value="">
                    </div>


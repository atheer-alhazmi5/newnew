                        <label class="btn-attach" for="ugEditAttachInput"><i class="bi bi-paperclip"></i> إرفاق صورة</label>
                        <button type="button" class="btn-attach-clear d-none" id="ugEditAttachClear" onclick="ugClearAttach('Edit')"><i class="bi bi-x-lg"></i> إزالة</button>
                        <input type="file" id="ugEditAttachInput" accept="image/*">
                        <input type="hidden" id="ugEditAttachData" value="">
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-6">
                        <label class="form-label">اللون</label>
                        <div class="d-flex align-items-center gap-3">
                            <div class="ug-color-picker-wrap">
                                <input type="color" id="ugEditColor" value="#25935F" oninput="document.getElementById('ugEditColorHex').textContent=this.value">
                            </div>
                            <div class="ug-color-hex" id="ugEditColorHex">#25935F</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <label class="form-label">التفعيل</label>
                        <div class="d-flex align-items-center gap-3 mt-2">
                            <div class="form-check form-switch m-0">
                                <input class="form-check-input" type="checkbox" id="ugEditIsActive" style="width:48px;height:24px;">
                            </div>
                            <label class="form-check-label" for="ugEditIsActive" id="ugEditIsActiveLabel" style="font-weight:600;">مفعل</label>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">الملاحظات</label>
                    <textarea class="form-control" id="ugEditNotes" rows="2"></textarea>
                </div>

                <div id="ugEditError" class="alert alert-danger d-none" style="font-size:14px;"></div>
            </div>
            <div class="ug-modal-footer">
                <button class="ug-save-btn" onclick="ugSubmitEdit()">
                    <i class="bi bi-check-lg"></i>حفظ التعديلات
                </button>
                <button class="ug-cancel-btn" data-bs-dismiss="modal">إلغاء</button>
            </div>
        </div>
    </div>
</div>

<!-- Details  -->
<div class="modal fade" id="ugDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content ug-modal">
            <div class="ug-modal-header" style="background:var(--info-700);">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="ug-modal-title"><i class="bi bi-eye" style="margin-left:8px;"></i>تفاصيل العنصر</h5>
                <div class="ug-modal-subtitle">عرض كامل البيانات</div>
            </div>
            <div class="ug-modal-body" id="ugDetailsBody"></div>
            <div class="ug-modal-footer" style="justify-content:flex-end;">
                <button class="ug-cancel-btn" data-bs-dismiss="modal">إغلاق</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete  -->
<div class="modal fade" id="ugDeleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content ug-modal">
            <div class="ug-modal-header" style="background:var(--error-600);">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="ug-modal-title"><i class="bi bi-trash3" style="margin-left:8px;"></i>حذف العنصر</h5>
            </div>
            <div class="ug-modal-body text-center">
                <input type="hidden" id="ugDeleteId">
                <p style="font-weight:700;font-size:16px;margin-top:8px;color:var(--gray-800);">هل أنت متأكد من حذف هذا العنصر؟</p>
                <p style="font-size:13.5px;color:var(--gray-500);" id="ugDeleteNameLabel"></p>
                <p style="font-size:12px;color:var(--error-600);background:var(--error-50);padding:8px 12px;border-radius:8px;border:1px solid var(--error-100);">لا يمكن حذف عنصر له عناصر فرعية مرتبطة. احذف أو انقل العناصر التابعة أولاً.</p>
                <div id="ugDeleteError" class="alert alert-danger d-none" style="font-size:14px;text-align:right;"></div>
            </div>
            <div class="ug-modal-footer" style="justify-content:center;background:var(--gray-50);">
                <button class="ug-save-btn" style="background:var(--error-600);" onclick="ugSubmitDelete()">نعم، حذف</button>
                <button class="ug-cancel-btn" data-bs-dismiss="modal">إلغاء</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js"></script>
<script src="~/js/user-guide.js?v=@DateTime.Now.Ticks"></script>
}

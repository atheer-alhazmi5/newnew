@{
    ViewBag.Title = "أنواع الإجراءات";
    ViewBag.PageName = "أنواع الإجراءات";
}

<style>
/* مطابقة تصميم صفحات الإعدادات (نفس أسلوب القوائم المنسدلة / أنواع النماذج) */
.ddl-modal { border-radius:20px; border:none; overflow:hidden; box-shadow:0 20px 60px rgba(0,0,0,.15); }
.ddl-modal-header { padding:24px 28px; position:relative; }
.ddl-modal-header.create { background:var(--sa-800); }
.ddl-modal-header.details { background:var(--info-700); }
.ddl-modal-header.edit { background:var(--sa-800); }
.ddl-modal-header.delete { background:var(--error-600); }
.ddl-modal-header .btn-close-x { position:absolute; top:16px; left:16px; background:none; border:none; color:rgba(255,255,255,.7); font-size:22px; cursor:pointer; }
.ddl-modal-header .btn-close-x:hover { color:#fff; }
.ddl-modal-title { color:#fff; font-weight:800; font-size:20px; margin:0; }
.ddl-modal-subtitle { color:rgba(255,255,255,.8); font-size:14px; margin-top:4px; }
.ddl-modal-body { padding:28px; max-height:75vh; overflow-y:auto; }
.ddl-modal-footer { padding:20px 28px; display:flex; flex-wrap:wrap; gap:12px; border:none; justify-content:space-between; align-items:center; background:var(--gray-50); }
.ddl-save-btn { padding:12px 32px; border-radius:12px; font-size:15px; font-weight:700; font-family:'Cairo',sans-serif; border:none; cursor:pointer; background:var(--sa-600); color:#fff; }
.ddl-save-btn:hover { background:var(--sa-700); transform:translateY(-1px); }
.ddl-cancel-btn { padding:12px 32px; border-radius:12px; font-size:15px; font-weight:700; font-family:'Cairo',sans-serif; border:none; cursor:pointer; background:#6b7280; color:#fff; }
.ddl-cancel-btn:hover { background:#4b5563; }
.ddl-section { background:#fff; border-radius:14px; padding:20px 24px; margin-bottom:20px; border:1px solid var(--gray-200); }
.ddl-section-title { font-weight:800; font-size:16px; color:var(--sa-800); margin:0 0 18px 0; padding-bottom:12px; border-bottom:2px solid var(--sa-100); display:flex; align-items:center; gap:8px; }
.required-star { color:#ef4444; margin-right:4px; }
.ddl-action-btn { min-width:auto; border-radius:8px; font-weight:700; padding:5px 10px; font-size:11px; display:inline-flex; align-items:center; gap:4px; justify-content:center; cursor:pointer; border:2px solid transparent; font-family:'Cairo',sans-serif; white-space:nowrap; }
.ddl-action-btn-detail { border-color:var(--info-500); color:var(--info-500); background:#fff; }
.ddl-action-btn-detail:hover { background:var(--info-50); }
.ddl-action-btn-edit { border-color:var(--sa-600); color:var(--sa-600); background:#fff; }
.ddl-action-btn-edit:hover { background:var(--sa-50); }
.ddl-action-btn-delete { border-color:var(--error-500); color:var(--error-500); background:#fff; }
.ddl-action-btn-delete:hover { background:var(--error-50); }
.ddl-page-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:24px; flex-wrap:wrap; gap:12px; }
.ddl-search-box { position:relative; min-width:180px; max-width:280px; }
.ddl-search-box input { padding-right:42px; border-radius:12px; border:2px solid var(--gray-200); font-size:13px; height:40px; width:100%; }
.ddl-search-box input:focus { border-color:var(--sa-400); }
.ddl-search-box .ddl-search-icon { position:absolute; right:14px; top:50%; transform:translateY(-50%); color:var(--gray-400); font-size:16px; }
.ddl-page-wrap { width:100%; max-width:100%; }
.ddl-filters { display:flex; flex-wrap:wrap; gap:10px; align-items:center; }
.ddl-filter-select { min-width:140px; width:auto; border-radius:10px; border:2px solid var(--gray-200); padding:8px 12px; font-size:13px; font-family:'Cairo',sans-serif; }
.ddl-clear-btn { padding:8px 16px; border-radius:10px; font-weight:700; font-size:13px; background:var(--gray-100); color:var(--gray-700); border:2px solid var(--gray-200); cursor:pointer; white-space:nowrap; font-family:'Cairo',sans-serif; }
.ddl-clear-btn:hover { background:var(--gray-200); }
.ddl-badge-active { background:#dcf5e8; color:#0f9f5c; padding:6px 12px; border-radius:999px; font-weight:700; font-size:12px; }
.ddl-badge-inactive { background:#fde8e8; color:#ef4444; padding:6px 12px; border-radius:999px; font-weight:700; font-size:12px; }
#patTable thead th { background:var(--gray-50) !important; color:var(--gray-700); font-size:13px; font-weight:700; white-space:nowrap; border-bottom:2px solid var(--gray-200); }
#patTable tbody td { vertical-align:middle; font-size:13px; }
#patTable tbody tr:hover { background:var(--sa-25); }
.pat-toggle { position:relative; display:inline-block; width:42px; height:22px; }
.pat-toggle input { opacity:0; width:0; height:0; }
.pat-toggle .pat-slider { position:absolute; cursor:pointer; inset:0; background:var(--gray-300); border-radius:22px; transition:.25s; }
.pat-toggle .pat-slider::before { content:''; position:absolute; width:16px; height:16px; left:3px; bottom:3px; background:#fff; border-radius:50%; transition:.25s; }
.pat-toggle input:checked + .pat-slider { background:var(--sa-600); }
.pat-toggle input:checked + .pat-slider::before { transform:translateX(20px); }
.pat-toggle input:disabled + .pat-slider { opacity:.45; cursor:not-allowed; }
@@media (max-width:768px) { .pat-form-row { grid-template-columns:1fr !important; } }
.pat-form-row { display:grid; grid-template-columns:repeat(2,1fr); gap:16px; }
</style>

<div class="ddl-page-wrap">
<div class="ddl-page-header">
    <div>
        <h2 class="page-title" style="margin:0;">أنواع الإجراءات</h2>
        <p style="color:var(--gray-500);font-size:14px;margin:6px 0 0;">إدارة أنواع الإجراءات المستخدمة في النظام</p>
    </div>
    <button type="button" class="btn btn-primary" onclick="patShowCreateModal()" style="border-radius:12px;padding:10px 28px;font-weight:700;font-size:14px;display:inline-flex;align-items:center;gap:8px;">
        <i class="bi bi-plus-lg"></i> إضافة نوع إجراء
    </button>
</div>

<div class="d-flex gap-3 mb-4 flex-wrap align-items-center ddl-filters" id="patFiltersWrap">
    <div class="ddl-search-box">
        <i class="bi bi-search ddl-search-icon"></i>
        <input type="text" class="form-control" id="patSearchInput" placeholder="بحث بالاسم أو الوصف..." autocomplete="off">
    </div>
    <select class="ddl-filter-select form-select" id="patFilterStatus">
        <option value="">الحالة</option>
        <option value="1">مفعل</option>
        <option value="0">غير مفعل</option>
    </select>
    <button type="button" class="ddl-clear-btn" id="patFilterClear" title="مسح الفلاتر"><i class="bi bi-x-circle"></i> مسح</button>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive" style="overflow-x:auto;">
            <table class="table mb-0" id="patTable">
                <thead>
                    <tr>
                        <th style="width:56px;text-align:center;">الترتيب</th>
                        <th>اسم نوع الإجراء</th>
                        <th>الوصف</th>
                        <th style="width:120px;text-align:center;">التفعيل</th>
                        <th style="width:220px;text-align:center;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody id="patBody">
                    <tr><td colspan="5" class="text-center py-4"><div class="spinner-border" style="color:var(--sa-600);"></div></td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="patPaginationContainer" class="d-flex justify-content-center mt-4"></div>
</div>

<!-- إنشاء -->
<div class="modal fade" id="patCreateModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content ddl-modal">
            <div class="ddl-modal-header create">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="ddl-modal-title"><i class="bi bi-plus-circle" style="margin-left:8px;"></i> إضافة نوع إجراء</h5>
                <div class="ddl-modal-subtitle">أدخل بيانات نوع الإجراء الجديد</div>
            </div>
            <div class="ddl-modal-body">
                <div class="ddl-section">
                    <div class="ddl-section-title"><i class="bi bi-diagram-3"></i> البيانات الأساسية</div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">اسم نوع الإجراء<span class="required-star">*</span></label>
                        <input type="text" class="form-control" id="patCreateName" maxlength="200" autocomplete="off" style="border-radius:10px;border:2px solid var(--gray-200);">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">الوصف</label>
                        <textarea class="form-control" id="patCreateDescription" rows="3" placeholder="وصف اختياري" style="border-radius:10px;border:2px solid var(--gray-200);"></textarea>
                    </div>
                    <div class="mb-0">
                        <label class="form-label fw-bold">التفعيل</label>
                        <div class="d-flex gap-3 mt-2">
                            <div class="form-check"><input class="form-check-input" type="radio" name="patCreateIsActive" id="patCreateIsActiveOn" value="1" checked><label class="form-check-label" for="patCreateIsActiveOn">مفعل</label></div>
                            <div class="form-check"><input class="form-check-input" type="radio" name="patCreateIsActive" id="patCreateIsActiveOff" value="0"><label class="form-check-label" for="patCreateIsActiveOff">معطل</label></div>
                        </div>
                    </div>
                </div>
                <div id="patCreateError" class="alert alert-danger d-none" style="font-size:14px;"></div>
            </div>
            <div class="ddl-modal-footer" style="justify-content:flex-end;">
                <div class="d-flex gap-2 flex-wrap">
                    <button type="button" class="ddl-save-btn" onclick="patSubmitCreate()">حفظ</button>
                    <button type="button" class="ddl-cancel-btn" data-bs-dismiss="modal">إلغاء</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- تعديل -->
<div class="modal fade" id="patEditModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content ddl-modal">
            <div class="ddl-modal-header edit">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="ddl-modal-title"><i class="bi bi-pencil-square" style="margin-left:8px;"></i> تعديل نوع الإجراء</h5>
                <div class="ddl-modal-subtitle">تحديث بيانات نوع الإجراء</div>
            </div>
            <div class="ddl-modal-body">
                <input type="hidden" id="patEditId">
                <input type="hidden" id="patEditSortOriginal">
                <div class="ddl-section">
                    <div class="ddl-section-title"><i class="bi bi-diagram-3"></i> البيانات الأساسية</div>
                    <div class="pat-form-row mb-3">
                        <div>
                            <label class="form-label fw-bold">اسم نوع الإجراء<span class="required-star">*</span></label>
                            <input type="text" class="form-control" id="patEditName" maxlength="200" autocomplete="off" style="border-radius:10px;border:2px solid var(--gray-200);">
                        </div>
                        <div>
                            <label class="form-label fw-bold">الترتيب</label>
                            <input type="number" class="form-control" id="patEditSortOrder" min="1" step="1" style="border-radius:10px;border:2px solid var(--gray-200);">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">الوصف</label>
                        <textarea class="form-control" id="patEditDescription" rows="3" style="border-radius:10px;border:2px solid var(--gray-200);"></textarea>
                    </div>
                    <div class="mb-0">
                        <label class="form-label fw-bold">التفعيل</label>
                        <div class="d-flex gap-3 mt-2">
                            <div class="form-check"><input class="form-check-input" type="radio" name="patEditIsActive" id="patEditIsActiveOn" value="1"><label class="form-check-label" for="patEditIsActiveOn">مفعل</label></div>
                            <div class="form-check"><input class="form-check-input" type="radio" name="patEditIsActive" id="patEditIsActiveOff" value="0"><label class="form-check-label" for="patEditIsActiveOff">معطل</label></div>
                        </div>
                    </div>
                </div>
                <div id="patEditError" class="alert alert-danger d-none" style="font-size:14px;"></div>
            </div>
            <div class="ddl-modal-footer" style="justify-content:flex-end;">
                <div class="d-flex gap-2 flex-wrap">
                    <button type="button" class="ddl-save-btn" onclick="patSubmitEdit()">حفظ التعديلات</button>
                    <button type="button" class="ddl-cancel-btn" data-bs-dismiss="modal">إلغاء</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- تفاصيل -->
<div class="modal fade" id="patDetailModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content ddl-modal">
            <div class="ddl-modal-header details">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="ddl-modal-title"><i class="bi bi-eye" style="margin-left:8px;"></i> تفاصيل نوع الإجراء</h5>
                <div class="ddl-modal-subtitle">عرض بيانات السجل</div>
            </div>
            <div class="ddl-modal-body" id="patDetailBody"></div>
            <div class="ddl-modal-footer" style="justify-content:flex-end;">
                <button type="button" class="ddl-cancel-btn" data-bs-dismiss="modal">إغلاق</button>
            </div>
        </div>
    </div>
</div>

<!-- حذف -->
<div class="modal fade" id="patDeleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content ddl-modal">
            <div class="ddl-modal-header delete">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="ddl-modal-title">حذف نوع الإجراء</h5>
            </div>
            <div class="ddl-modal-body text-center">
                <input type="hidden" id="patDeleteId">
                <p style="font-weight:700;font-size:16px;margin-top:8px;color:var(--gray-800);">هل أنت متأكد من حذف نوع الإجراء؟</p>
                <p style="font-size:14px;color:var(--gray-500);" id="patDeleteNameLabel"></p>
                <div id="patDeleteError" class="alert alert-danger d-none" style="font-size:14px;text-align:right;"></div>
            </div>
            <div class="ddl-modal-footer" style="justify-content:center;">
                <button class="ddl-save-btn" style="background:var(--error-600);" onclick="patSubmitDelete()">نعم، حذف</button>
                <button class="ddl-cancel-btn" data-bs-dismiss="modal">إلغاء</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/procedure-action-types.js?v=@DateTime.Now.Ticks"></script>
}

@{
    ViewBag.Title = "لوحة المعلومات";
    ViewBag.PageName = "لوحة المعلومات";
}

<style>
.dash-header { margin-bottom:24px; }
.dash-subtitle { color:var(--gray-500); font-size:14px; margin:6px 0 0; }
.dash-tabs-wrap { background:#fff; border:1px solid var(--gray-200); border-radius:14px; overflow:hidden; margin-bottom:24px; box-shadow:var(--shadow); }
.dash-tabs { display:flex; border-bottom:1px solid var(--gray-200); background:#fff; overflow-x:auto; }
.dash-tab {
    flex:1; min-width:140px; padding:14px 12px; text-align:center;
    font-size:13px; font-weight:700; color:var(--gray-400);
    border-bottom:3px solid transparent; background:none; border-top:none; border-left:none; border-right:none;
    display:flex; align-items:center; justify-content:center; gap:7px;
    transition:all .2s; cursor:pointer; font-family:'Cairo',sans-serif; white-space:nowrap;
}
.dash-tab:hover { color:var(--sa-700); background:var(--sa-25); }
.dash-tab.active { color:var(--sa-700); border-bottom-color:var(--sa-500); background:var(--sa-25); }
.dash-tab i { font-size:15px; }
.dash-panel { display:none; }
.dash-panel.active { display:block; }
.dash-panel-inner { padding:24px; }
.dash-chart-row { display:grid; grid-template-columns:repeat(2,1fr); gap:20px; margin-top:8px; }
.dash-chart-card { background:#fff; border:1px solid var(--gray-200); border-radius:14px; padding:20px 22px; box-shadow:var(--shadow); }
.dash-chart-title { font-weight:800; font-size:14px; color:var(--sa-800); padding-bottom:10px; border-bottom:2px solid var(--sa-100); margin-bottom:14px; display:flex; align-items:center; gap:8px; }
.dash-chart-title i { color:var(--sa-600); font-size:16px; }
.dash-chart-wrap { position:relative; min-height:280px; }
.dash-future-card { display:flex; align-items:center; justify-content:center; min-height:280px; background:var(--gray-50); border:2px dashed var(--gray-200); border-radius:12px; color:var(--gray-400); font-weight:700; font-size:14px; flex-direction:column; gap:10px; }
.dash-future-card i { font-size:36px; color:var(--gray-300); }
.dash-profile-grid { display:grid; grid-template-columns:220px 1fr; gap:28px; align-items:start; }
.dash-avatar-wrap { text-align:center; }
.dash-avatar {
    width:140px; height:140px; border-radius:50%; object-fit:cover;
    border:4px solid var(--sa-100); background:var(--gray-100);
    display:inline-flex; align-items:center; justify-content:center;
    font-size:48px; color:var(--sa-600); overflow:hidden;
}
.dash-avatar img { width:100%; height:100%; object-fit:cover; }
.dash-fields { display:grid; grid-template-columns:160px 1fr; gap:12px 18px; font-size:13.5px; margin-bottom:24px; }
.dash-fields .lbl { font-weight:700; color:var(--gray-500); }
.dash-fields .val { color:var(--gray-800); font-weight:600; word-break:break-word; }
.dash-sign-box {
    border:1px solid var(--gray-200); border-radius:12px; padding:14px;
    background:var(--gray-50); min-height:90px; display:flex; align-items:center; justify-content:center;
}
.dash-sign-box img { max-height:72px; max-width:100%; object-fit:contain; }
.dash-sign-label { font-weight:800; font-size:14px; color:var(--sa-800); margin:20px 0 10px; display:flex; align-items:center; gap:8px; }
.dash-sign-label i { color:var(--sa-600); }
.dash-soon { text-align:center; padding:80px 24px; color:var(--gray-400); }
.dash-soon i { font-size:56px; display:block; margin-bottom:16px; color:var(--gray-300); }
.dash-soon h4 { font-weight:800; color:var(--gray-500); margin:0; font-size:22px; }
.dash-section-title { font-weight:800; font-size:15px; color:var(--sa-800); margin:0 0 14px; padding-bottom:10px; border-bottom:2px solid var(--sa-100); display:flex; align-items:center; gap:8px; }
.dash-section-title i { color:var(--sa-600); }
.dash-del-block { margin-bottom:28px; }
.dash-del-block:last-child { margin-bottom:0; }
.dash-table thead th { background:var(--gray-50) !important; color:var(--gray-700); font-size:13px; font-weight:700; text-align:center; white-space:nowrap; border-bottom:2px solid var(--gray-200); padding:12px 14px; }
.dash-table tbody td { vertical-align:middle; font-size:13px; padding:12px 14px; text-align:center; border-bottom:1px solid var(--gray-100); }
.dash-table tbody tr:hover { background:var(--sa-25); }
.dash-al-badge { display:inline-flex; align-items:center; gap:5px; padding:4px 12px; border-radius:20px; font-size:12px; font-weight:700; white-space:nowrap; background:var(--gray-100); color:var(--gray-700); }
.dash-al-ip { direction:ltr; unicode-bidi:embed; font-family:'Consolas','Courier New',monospace; font-size:12px; color:var(--gray-600); }
.dash-sign-canvas { border:2px dashed var(--gray-300); border-radius:12px; background:var(--gray-50); cursor:crosshair; touch-action:none; }
.dash-sign-canvas-wrap { display:flex; flex-direction:column; gap:8px; }
.dash-sign-canvas-wrap .btn-sm { padding:6px 14px; font-size:12px; }
.dash-attach-preview { max-width:120px; max-height:100px; border-radius:8px; object-fit:contain; border:1px solid var(--gray-300); }
.dash-attach-preview-wrap { display:flex; flex-direction:column; gap:6px; align-items:flex-start; }
.dash-sign-section { margin-top:8px; padding-top:20px; border-top:1px solid var(--gray-200); }
.dash-sign-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:20px; }
.dash-sign-locked-note { font-size:12px; color:var(--gray-500); margin-bottom:12px; }
@@media (max-width:992px) {
    .dash-chart-row { grid-template-columns:1fr; }
    .dash-profile-grid { grid-template-columns:1fr; }
    .dash-tab { min-width:120px; font-size:12px; padding:12px 8px; }
}
@@media (max-width:768px) {
    .dash-sign-grid { grid-template-columns:1fr; }
}
</style>

<div class="dash-header">
    <h2 class="page-title mb-0">لوحة المعلومات</h2>
    <p class="dash-subtitle">مرحباً بك، @ViewBag.UserFullName — إدارة ملفك الشخصي ومتابعة نشاطك</p>
</div>

<div class="dash-tabs-wrap">
    <div class="dash-tabs" id="dashTabs">
        <button type="button" class="dash-tab active" data-tab="summary" onclick="dashSelectTab('summary')"><i class="bi bi-speedometer2"></i> الملخص العام</button>
        <button type="button" class="dash-tab" data-tab="profile" onclick="dashSelectTab('profile')"><i class="bi bi-person-badge"></i> البيانات الأساسية</button>
        <button type="button" class="dash-tab" data-tab="delegations" onclick="dashSelectTab('delegations')"><i class="bi bi-arrow-left-right"></i> التفويضات</button>
        <button type="button" class="dash-tab" data-tab="audit" onclick="dashSelectTab('audit')"><i class="bi bi-clock-history"></i> سجل العمليات</button>
    </div>

    <!-- 1: الملخص العام -->
    <div class="dash-panel active" id="dashPanelSummary">
        <div class="dash-panel-inner">
            <div class="row g-4 mb-2">
                <div class="col-md-6 col-lg-4">
                    <div class="kpi-card" data-color="green">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <div class="kpi-label">صندوق الوارد</div>
                                <div class="kpi-value" style="color:var(--sa-600);" id="dashKpiInbox">0</div>
                                <div class="kpi-sub">إجمالي</div>
                            </div>
                            <div class="kpi-icon" style="background:var(--sa-100);color:var(--sa-600);"><i class="bi bi-inbox-fill"></i></div>
                        </div>
                        <div class="kpi-progress"><div class="kpi-progress-bar" id="dashKpiInboxBar" style="width:0%;background:var(--sa-500);"></div></div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="kpi-card" data-color="gold">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <div class="kpi-label">صندوق الصادر</div>
                                <div class="kpi-value" style="color:var(--gold-700);" id="dashKpiOutbox">0</div>
                                <div class="kpi-sub">إجمالي</div>
                            </div>
                            <div class="kpi-icon" style="background:var(--gold-100);color:var(--gold-700);"><i class="bi bi-send-fill"></i></div>
                        </div>
                        <div class="kpi-progress"><div class="kpi-progress-bar" id="dashKpiOutboxBar" style="width:0%;background:var(--gold-500);"></div></div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="kpi-card" data-color="green">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <div class="kpi-label">التفويضات</div>
                                <div class="kpi-value" style="color:var(--sa-600);" id="dashKpiDel">0</div>
                                <div class="kpi-sub">إجمالي</div>
                            </div>
                            <div class="kpi-icon" style="background:var(--sa-100);color:var(--sa-600);"><i class="bi bi-arrow-left-right"></i></div>
                        </div>
                        <div class="kpi-progress"><div class="kpi-progress-bar" id="dashKpiDelBar" style="width:0%;background:var(--sa-500);"></div></div>
                    </div>
                </div>
            </div>

            <div class="dash-chart-row">
                <div class="dash-chart-card">
                    <div class="dash-chart-title" id="dashChartTitle"><i class="bi bi-pie-chart-fill"></i> النسبة المئوية لعدد الطلبات حسب الحالة</div>
                    <div class="dash-chart-wrap"><canvas id="dashStatusChart"></canvas></div>
                </div>
                <div class="dash-chart-card">
                    <div class="dash-chart-title"><i class="bi bi-grid-1x2"></i> مساحة مستقبلية</div>
                    <div class="dash-future-card"><i class="bi bi-plus-square-dotted"></i><span>متاح للاستخدامات المستقبلية</span></div>
                </div>
            </div>
        </div>
    </div>

    <!-- 2: البيانات الأساسية -->
    <div class="dash-panel" id="dashPanelProfile">
        <div class="dash-panel-inner" id="dashProfileHost">
            <div class="text-center py-5"><div class="spinner-border" style="color:var(--sa-600);"></div></div>
        </div>
    </div>

    <!-- 3: التفويضات -->
    <div class="dash-panel" id="dashPanelDelegations">
        <div class="dash-panel-inner">
            <div class="d-flex gap-3 mb-4 flex-wrap align-items-center rt-filters">
                <div class="rt-search-box flex-grow-1" style="max-width:280px;position:relative;">
                    <i class="bi bi-search rt-search-icon"></i>
                    <input type="text" class="form-control" id="dashDelSearch" placeholder="بحث بالاسم..." oninput="dashDelApplyFilters()" style="padding-right:42px;border-radius:12px;border:2px solid var(--gray-200);height:44px;">
                </div>
                <select class="rt-filter-select form-select" id="dashDelType" onchange="dashDelApplyFilters()" style="max-width:180px;height:44px;">
                    <option value="">نوع التفويض</option>
                    <option value="delegator">مفوض (صادر)</option>
                    <option value="delegatee">مفوض له (وارد)</option>
                </select>
                <select class="rt-filter-select form-select" id="dashDelOrgUnit" onchange="dashDelApplyFilters()" style="max-width:200px;height:44px;">
                    <option value="">الوحدة التنظيمية</option>
                </select>
                <select class="rt-filter-select form-select" id="dashDelStatus" onchange="dashDelApplyFilters()" style="max-width:160px;height:44px;">
                    <option value="">الحالة</option>
                    <option value="active">ساري</option>
                    <option value="scheduled">مجدول</option>
                    <option value="expired">منتهي</option>
                    <option value="cancelled">ملغى</option>
                    <option value="draft">مسودة</option>
                </select>
                <input type="date" class="dash-date-input" id="dashDelDateFrom" onchange="dashDelApplyFilters()" aria-label="من تاريخ">
                <input type="date" class="dash-date-input" id="dashDelDateTo" onchange="dashDelApplyFilters()" aria-label="إلى تاريخ">
                <button type="button" class="rt-clear-btn" onclick="dashDelClearFilters()"><i class="bi bi-x-circle"></i> مسح</button>
            </div>

            <div class="dash-del-block">
                <h3 class="dash-section-title"><i class="bi bi-person-check"></i> جدول مفوض عنه</h3>
                <div class="card"><div class="card-body p-0"><div class="table-responsive">
                    <table class="table mb-0 dash-table"><thead><tr>
                        <th style="width:50px;">ت</th><th>المرجع</th><th>المفوض عنه</th><th>الوحدة التنظيمية</th>
                        <th>تاريخ البداية</th><th>تاريخ النهاية</th><th>سبب التفويض</th><th>المدة</th><th>الحالة</th>
                    </tr></thead><tbody id="dashDelDelegatorBody"><tr><td colspan="9" class="text-center py-4"><div class="spinner-border" style="color:var(--sa-600);"></div></td></tr></tbody></table>
                </div></div></div>
            </div>

            <div class="dash-del-block">
                <h3 class="dash-section-title"><i class="bi bi-person-plus"></i> جدول مفوض له</h3>
                <div class="card"><div class="card-body p-0"><div class="table-responsive">
                    <table class="table mb-0 dash-table"><thead><tr>
                        <th style="width:50px;">ت</th><th>المرجع</th><th>المفوض له</th><th>الوحدة التنظيمية</th>
                        <th>تاريخ البداية</th><th>تاريخ النهاية</th><th>سبب التفويض</th><th>المدة</th><th>الحالة</th>
                    </tr></thead><tbody id="dashDelDelegateeBody"><tr><td colspan="9" class="text-center py-4"><div class="spinner-border" style="color:var(--sa-600);"></div></td></tr></tbody></table>
                </div></div></div>
            </div>
        </div>
    </div>

    <!-- 4: سجل العمليات -->
    <div class="dash-panel" id="dashPanelAudit">
        <div class="dash-panel-inner">
            <div class="d-flex gap-3 mb-4 flex-wrap align-items-center rt-filters">
                <select class="rt-filter-select form-select" id="dashAlAction" onchange="dashAlApplyFilters()" style="max-width:220px;height:44px;">
                    <option value="">العملية</option>
                </select>
                <input type="date" class="dash-date-input" id="dashAlDateFrom" onchange="dashAlApplyFilters()" aria-label="من تاريخ">
                <input type="date" class="dash-date-input" id="dashAlDateTo" onchange="dashAlApplyFilters()" aria-label="إلى تاريخ">
                <button type="button" class="rt-clear-btn" onclick="dashAlClearFilters()"><i class="bi bi-x-circle"></i> مسح</button>
            </div>
            <div class="card"><div class="card-body p-0"><div class="table-responsive">
                <table class="table mb-0 dash-table"><thead><tr>
                    <th style="width:50px;">ت</th><th>العملية / الحركة</th><th style="width:170px;">تاريخ ووقت العملية</th>
                    <th style="width:100px;">المتصفح</th><th style="width:130px;">عنوان IP</th><th style="width:120px;">نظام التشغيل</th>
                </tr></thead><tbody id="dashAlBody"><tr><td colspan="6" class="text-center py-4"><div class="spinner-border" style="color:var(--sa-600);"></div></td></tr></tbody></table>
            </div></div></div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/dashboard.js?v=@DateTime.Now.Ticks"></script>
<script>dashInit();</script>
}

@{
    ViewBag.Title = "تقييم النظام";
    ViewBag.PageName = "تقييم النظام";
    var isAdmin = ViewBag.IsAdmin == true;
}

<style>
.se-page-header { display:flex; justify-content:space-between; align-items:flex-start; gap:12px; flex-wrap:wrap; margin-bottom:24px; }
.se-subtitle { color:var(--gray-500); font-size:14px; margin:6px 0 0; }
.se-header-actions { display:flex; flex-direction:column; align-items:flex-end; gap:8px; }
.se-already-msg { font-size:13px; font-weight:700; color:var(--info-700); background:var(--info-50); border:1px solid var(--info-100); border-radius:10px; padding:8px 14px; display:none; }
.se-already-msg.show { display:inline-flex; align-items:center; gap:6px; }
.se-charts-row { display:grid; grid-template-columns:repeat(2,1fr); gap:20px; margin-bottom:24px; }
.se-chart-card { background:#fff; border:1px solid var(--gray-200); border-radius:14px; padding:20px 22px; box-shadow:var(--shadow); }
.se-chart-title { font-weight:800; font-size:14px; color:var(--sa-800); padding-bottom:10px; border-bottom:2px solid var(--sa-100); margin-bottom:14px; display:flex; align-items:center; gap:8px; }
.se-chart-title i { color:var(--sa-600); font-size:16px; }
.se-chart-wrap { position:relative; min-height:280px; }
.se-table-card { border-radius:14px; border:1px solid var(--gray-200); overflow:hidden; box-shadow:var(--shadow); }
.se-table thead th { background:var(--gray-50) !important; color:var(--gray-700); font-size:13px; font-weight:700; text-align:center; white-space:nowrap; border-bottom:2px solid var(--gray-200); padding:12px 14px; }
.se-table tbody td { vertical-align:middle; font-size:13px; padding:12px 14px; text-align:center; border-bottom:1px solid var(--gray-100); }
.se-table tbody tr:hover { background:var(--sa-25); }
.se-rating-pill { display:inline-flex; align-items:center; gap:4px; padding:4px 10px; border-radius:999px; font-weight:700; font-size:12px; white-space:nowrap; }
.se-rating-excellent { background:#d1fae5; color:#047857; border:1px solid #6ee7b7; }
.se-rating-good { background:#ecfdf5; color:#059669; border:1px solid #a7f3d0; }
.se-rating-average { background:#fef3c7; color:#b45309; border:1px solid #fcd34d; }
.se-rating-low { background:#ffedd5; color:#c2410c; border:1px solid #fdba74; }
.se-rating-verylow { background:#fee2e2; color:#b91c1c; border:1px solid #fca5a5; }
.se-notes-cell { max-width:220px; text-align:right !important; white-space:pre-wrap; word-break:break-word; color:var(--gray-700); }
.se-publish-btn { min-width:auto; border-radius:8px; font-weight:700; padding:5px 12px; font-size:11.5px; display:inline-flex; align-items:center; gap:4px; cursor:pointer; border:2px solid transparent; font-family:'Cairo',sans-serif; white-space:nowrap; transition:all .15s; background:#fff; }
.se-publish-on { border-color:var(--success-500); color:var(--success-600); }
.se-publish-on:hover { background:var(--success-50); }
.se-publish-off { border-color:var(--gray-300); color:var(--gray-600); }
.se-publish-off:hover { background:var(--gray-50); }
.se-empty { text-align:center; padding:40px 20px; color:var(--gray-500); }
.se-modal .modal-content { border-radius:20px; border:none; overflow:hidden; box-shadow:0 20px 60px rgba(0,0,0,.15); }
.se-modal-header { background:var(--sa-800); padding:24px 28px; position:relative; }
.se-modal-header .btn-close-x { position:absolute; top:16px; left:16px; background:none; border:none; color:rgba(255,255,255,.7); font-size:22px; cursor:pointer; }
.se-modal-title { color:#fff; font-weight:800; font-size:20px; margin:0; }
.se-modal-subtitle { color:rgba(255,255,255,.7); font-size:14px; margin-top:4px; }
.se-modal-body { padding:24px 28px 20px; max-height:75vh; overflow-y:auto; }
.se-modal-footer { padding:18px 28px; display:flex; gap:12px; border:none; justify-content:flex-start; background:var(--gray-50); border-top:1px solid var(--gray-200); }
.se-form-section { margin-bottom:20px; }
.se-form-section:last-child { margin-bottom:0; }
.se-section-label { font-weight:800; font-size:14px; color:var(--sa-800); margin-bottom:10px; display:flex; align-items:center; gap:8px; }
.se-section-label i { color:var(--sa-600); font-size:15px; }
.se-section-label .req { color:#ef4444; margin-right:2px; }
.se-section-hint { font-size:12px; color:var(--gray-500); margin-top:6px; }
/* التقييم العام — Choice Pills */
.se-overall-pills { display:flex; flex-wrap:wrap; gap:10px; }
.se-choice-pill {
    flex:1 1 calc(20% - 10px); min-width:88px;
    display:flex; flex-direction:column; align-items:center; justify-content:center; gap:6px;
    padding:12px 8px; border-radius:12px;
    background:#fff; border:2px solid var(--gray-200);
    cursor:pointer; font-family:'Cairo',sans-serif;
    transition:border-color .15s, background .15s, box-shadow .15s;
}
.se-choice-pill i { font-size:20px; color:var(--gray-400); transition:color .15s; }
.se-choice-pill span { font-size:12.5px; font-weight:700; color:var(--gray-700); line-height:1.2; text-align:center; }
.se-choice-pill:hover { border-color:var(--sa-300); background:var(--sa-25); }
.se-choice-pill:hover i { color:var(--sa-500); }
.se-choice-pill.is-selected { border-color:var(--sa-600); background:var(--sa-50); box-shadow:0 0 0 3px rgba(37,147,95,.12); }
.se-choice-pill.is-selected i { color:var(--sa-600); }
.se-choice-pill.is-selected span { color:var(--sa-800); }
.se-choice-pill[data-level="ممتاز"].is-selected { border-color:#047857; background:#ecfdf5; }
.se-choice-pill[data-level="ممتاز"].is-selected i { color:#047857; }
.se-choice-pill[data-level="جيد"].is-selected { border-color:#059669; background:#f0fdf4; }
.se-choice-pill[data-level="جيد"].is-selected i { color:#059669; }
.se-choice-pill[data-level="متوسط"].is-selected { border-color:#d97706; background:#fffbeb; }
.se-choice-pill[data-level="متوسط"].is-selected i { color:#d97706; }
.se-choice-pill[data-level="منخفض"].is-selected { border-color:#ea580c; background:#fff7ed; }
.se-choice-pill[data-level="منخفض"].is-selected i { color:#ea580c; }
.se-choice-pill[data-level="منخفض جداً"].is-selected { border-color:#dc2626; background:#fef2f2; }
.se-choice-pill[data-level="منخفض جداً"].is-selected i { color:#dc2626; }
/* التقييم التفصيلي */
.se-detail-block {
    background:var(--gray-50); border:1px solid var(--gray-200);
    border-radius:12px; padding:14px 16px; margin-bottom:12px;
}
.se-detail-block:last-child { margin-bottom:0; }
.se-detail-head { display:flex; align-items:center; justify-content:space-between; gap:10px; margin-bottom:10px; flex-wrap:wrap; }
.se-detail-name { font-weight:700; font-size:13.5px; color:var(--gray-800); display:flex; align-items:center; gap:7px; }
.se-detail-name i { color:var(--sa-600); font-size:14px; }
.se-detail-picked { font-size:12px; font-weight:700; color:var(--sa-700); background:var(--sa-100); border:1px solid var(--sa-200); border-radius:999px; padding:3px 10px; min-height:24px; }
.se-detail-picked.is-empty { color:var(--gray-400); background:var(--gray-100); border-color:var(--gray-200); font-weight:600; }
.se-dim-btns { display:flex; gap:6px; flex-wrap:wrap; }
.se-dim-btn {
    flex:1 1 auto; min-width:52px; padding:8px 6px;
    border-radius:10px; border:2px solid var(--gray-200); background:#fff;
    font-size:11.5px; font-weight:700; color:var(--gray-600);
    cursor:pointer; font-family:'Cairo',sans-serif; text-align:center;
    transition:border-color .15s, background .15s, color .15s;
    line-height:1.25;
}
.se-dim-btn:hover { border-color:var(--sa-300); color:var(--sa-700); background:var(--sa-25); }
.se-dim-btn.is-selected { border-color:var(--sa-600); background:var(--sa-600); color:#fff; }
.se-notes-wrap textarea {
    border-radius:12px; border:2px solid var(--gray-200); padding:12px 14px;
    font-size:13.5px; min-height:96px; resize:vertical; font-family:'Cairo',sans-serif;
    transition:border-color .15s, box-shadow .15s;
}
.se-notes-wrap textarea:focus { border-color:var(--sa-400); box-shadow:0 0 0 3px rgba(37,147,95,.1); outline:none; }
.se-notes-wrap textarea::placeholder { color:var(--gray-400); }
.se-submit-btn {
    border-radius:12px; padding:11px 32px; font-weight:800; font-size:14px;
    background:var(--sa-600); border:2px solid var(--sa-600); color:#fff;
    display:inline-flex; align-items:center; gap:8px; font-family:'Cairo',sans-serif;
    cursor:pointer; transition:background .15s, border-color .15s, transform .1s;
}
.se-submit-btn:hover:not(:disabled) { background:var(--sa-700); border-color:var(--sa-700); }
.se-submit-btn:active:not(:disabled) { transform:translateY(1px); }
.se-submit-btn:disabled { opacity:.6; cursor:not-allowed; }
.se-cancel-btn {
    border-radius:12px; padding:11px 28px; font-weight:700; font-size:14px;
    background:#fff; border:2px solid var(--gray-300); color:var(--gray-700);
    font-family:'Cairo',sans-serif; cursor:pointer; transition:background .15s;
}
.se-cancel-btn:hover { background:var(--gray-100); }
@@media (max-width:768px) {
    .se-choice-pill { flex:1 1 calc(33% - 10px); min-width:72px; }
    .se-dim-btn { min-width:46px; font-size:10.5px; padding:7px 4px; }
}
@@media (max-width:992px) { .se-charts-row { grid-template-columns:1fr; } }
</style>

<div class="se-page-header">
    <div>
        <h2 class="page-title mb-0">تقييم النظام :</h2>
        <p class="se-subtitle">استعراض تقييمات المستفيدين على النظام</p>
    </div>
    <div class="se-header-actions">
        <button type="button" class="btn btn-primary" id="seBtnEvaluate" style="border-radius:12px;padding:10px 28px;font-weight:700;" onclick="seOpenEvaluateModal()">
            <i class="bi bi-star-fill"></i> تقييم النظام
        </button>
        <div class="se-already-msg" id="seAlreadyMsg"><i class="bi bi-info-circle-fill"></i> تم إرسال تقييمك مسبقًا</div>
    </div>
</div>

<div class="se-charts-row">
    <div class="se-chart-card">
        <div class="se-chart-title"><i class="bi bi-bar-chart-fill"></i> تمثيل بياني يوضح عدد التقييمات التفصيلية للنظام</div>
        <div class="se-chart-wrap"><canvas id="seDetailChart"></canvas></div>
    </div>
    <div class="se-chart-card">
        <div class="se-chart-title"><i class="bi bi-pie-chart-fill"></i> تمثيل بياني يوضح النسبة المئوية لعدد التقييمات العامة للنظام</div>
        <div class="se-chart-wrap"><canvas id="seOverallChart"></canvas></div>
    </div>
</div>

<div class="card se-table-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0 se-table" id="seTable">
                <thead>
                    <tr>
                        <th style="width:50px;">ت</th>
                        <th>مقدم التقييم</th>
                        <th>الوحدة التنظيمية</th>
                        <th>تاريخ التقييم</th>
                        <th>التقييم العام</th>
                        <th>سهولة الاستخدام</th>
                        <th>التصميم</th>
                        <th>سرعة الأداء</th>
                        <th>الدعم الفني</th>
                        <th>الملاحظات / الرأي الإضافي</th>
                        @if (isAdmin)
                        {
                            <th style="width:110px;">النشر</th>
                        }
                    </tr>
                </thead>
                <tbody id="seBody">
                    <tr><td colspan="@(isAdmin ? 11 : 10)" class="text-center py-4"><div class="spinner-border" style="color:var(--sa-600);"></div></td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- مودال تقييم النظام — نفس الصفحة -->
<div class="modal fade se-modal" id="seEvaluateModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="se-modal-header">
                <button type="button" class="btn-close-x" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                <h5 class="se-modal-title">تقييم النظام</h5>
                <div class="se-modal-subtitle">شاركنا رأيك في النظام — التقييم مرة واحدة فقط</div>
            </div>
            <div class="se-modal-body">
                <div class="se-form-section">
                    <div class="se-section-label"><i class="bi bi-award"></i> التقييم العام للنظام <span class="req">*</span></div>
                    <div class="se-overall-pills" id="seOverallPills" role="group" aria-label="التقييم العام">
                        <button type="button" class="se-choice-pill" data-field="overall" data-level="ممتاز" onclick="sePickOverall(this)">
                            <i class="bi bi-emoji-smile-fill"></i><span>ممتاز</span>
                        </button>
                        <button type="button" class="se-choice-pill" data-field="overall" data-level="جيد" onclick="sePickOverall(this)">
                            <i class="bi bi-hand-thumbs-up-fill"></i><span>جيد</span>
                        </button>
                        <button type="button" class="se-choice-pill" data-field="overall" data-level="متوسط" onclick="sePickOverall(this)">
                            <i class="bi bi-dash-circle-fill"></i><span>متوسط</span>
                        </button>
                        <button type="button" class="se-choice-pill" data-field="overall" data-level="منخفض" onclick="sePickOverall(this)">
                            <i class="bi bi-arrow-down-circle-fill"></i><span>منخفض</span>
                        </button>
                        <button type="button" class="se-choice-pill" data-field="overall" data-level="منخفض جداً" onclick="sePickOverall(this)">
                            <i class="bi bi-exclamation-circle-fill"></i><span>منخفض جداً</span>
                        </button>
                    </div>
                    <div class="se-section-hint" id="seOverallHint">اختر مستوى رضاك العام عن النظام</div>
                </div>

                <div class="se-form-section">
                    <div class="se-section-label"><i class="bi bi-ui-checks-grid"></i> التقييم التفصيلي <span class="req">*</span></div>

                    <div class="se-detail-block" data-dim="ease">
                        <div class="se-detail-head">
                            <div class="se-detail-name"><i class="bi bi-mouse2"></i> سهولة الاستخدام</div>
                            <span class="se-detail-picked is-empty" id="sePickedEase">—</span>
                        </div>
                        <div class="se-dim-btns" role="group">
                            <button type="button" class="se-dim-btn" data-field="ease" data-level="ممتاز" onclick="sePickDim(this)">ممتاز</button>
                            <button type="button" class="se-dim-btn" data-field="ease" data-level="جيد" onclick="sePickDim(this)">جيد</button>
                            <button type="button" class="se-dim-btn" data-field="ease" data-level="متوسط" onclick="sePickDim(this)">متوسط</button>
                            <button type="button" class="se-dim-btn" data-field="ease" data-level="منخفض" onclick="sePickDim(this)">منخفض</button>
                            <button type="button" class="se-dim-btn" data-field="ease" data-level="منخفض جداً" onclick="sePickDim(this)">منخفض جداً</button>
                        </div>
                    </div>

                    <div class="se-detail-block" data-dim="design">
                        <div class="se-detail-head">
                            <div class="se-detail-name"><i class="bi bi-palette"></i> التصميم</div>
                            <span class="se-detail-picked is-empty" id="sePickedDesign">—</span>
                        </div>
                        <div class="se-dim-btns" role="group">
                            <button type="button" class="se-dim-btn" data-field="design" data-level="ممتاز" onclick="sePickDim(this)">ممتاز</button>
                            <button type="button" class="se-dim-btn" data-field="design" data-level="جيد" onclick="sePickDim(this)">جيد</button>
                            <button type="button" class="se-dim-btn" data-field="design" data-level="متوسط" onclick="sePickDim(this)">متوسط</button>
                            <button type="button" class="se-dim-btn" data-field="design" data-level="منخفض" onclick="sePickDim(this)">منخفض</button>
                            <button type="button" class="se-dim-btn" data-field="design" data-level="منخفض جداً" onclick="sePickDim(this)">منخفض جداً</button>
                        </div>
                    </div>

                    <div class="se-detail-block" data-dim="performance">
                        <div class="se-detail-head">
                            <div class="se-detail-name"><i class="bi bi-lightning-charge"></i> سرعة الأداء</div>
                            <span class="se-detail-picked is-empty" id="sePickedPerformance">—</span>
                        </div>
                        <div class="se-dim-btns" role="group">
                            <button type="button" class="se-dim-btn" data-field="performance" data-level="ممتاز" onclick="sePickDim(this)">ممتاز</button>
                            <button type="button" class="se-dim-btn" data-field="performance" data-level="جيد" onclick="sePickDim(this)">جيد</button>
                            <button type="button" class="se-dim-btn" data-field="performance" data-level="متوسط" onclick="sePickDim(this)">متوسط</button>
                            <button type="button" class="se-dim-btn" data-field="performance" data-level="منخفض" onclick="sePickDim(this)">منخفض</button>
                            <button type="button" class="se-dim-btn" data-field="performance" data-level="منخفض جداً" onclick="sePickDim(this)">منخفض جداً</button>
                        </div>
                    </div>

                    <div class="se-detail-block" data-dim="support">
                        <div class="se-detail-head">
                            <div class="se-detail-name"><i class="bi bi-headset"></i> الدعم الفني</div>
                            <span class="se-detail-picked is-empty" id="sePickedSupport">—</span>
                        </div>
                        <div class="se-dim-btns" role="group">
                            <button type="button" class="se-dim-btn" data-field="support" data-level="ممتاز" onclick="sePickDim(this)">ممتاز</button>
                            <button type="button" class="se-dim-btn" data-field="support" data-level="جيد" onclick="sePickDim(this)">جيد</button>
                            <button type="button" class="se-dim-btn" data-field="support" data-level="متوسط" onclick="sePickDim(this)">متوسط</button>
                            <button type="button" class="se-dim-btn" data-field="support" data-level="منخفض" onclick="sePickDim(this)">منخفض</button>
                            <button type="button" class="se-dim-btn" data-field="support" data-level="منخفض جداً" onclick="sePickDim(this)">منخفض جداً</button>
                        </div>
                    </div>
                </div>

                <div class="se-form-section se-notes-wrap">
                    <div class="se-section-label"><i class="bi bi-chat-left-text"></i> الملاحظات / الرأي الإضافي</div>
                    <textarea class="form-control" id="seFbNotes" rows="3"
                              placeholder="اكتب اقتراحاتك أو ملاحظاتك لتحسين النظام — اختياري"></textarea>
                </div>
            </div>
            <div class="se-modal-footer">
                <button type="button" class="se-submit-btn" id="seFbSubmitBtn" onclick="seSubmitFeedback()">
                    <i class="bi bi-send-fill"></i> إرسال التقييم
                </button>
                <button type="button" class="se-cancel-btn" data-bs-dismiss="modal">إلغاء</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    window.seIsAdmin = @(isAdmin ? "true" : "false");
</script>
<script src="~/js/system-evaluation.js?v=@DateTime.Now.Ticks"></script>
<script>seInit();</script>
}
